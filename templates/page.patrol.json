    "mc_media_image": {
      "type": "mc_media-image",
      "settings": {
        "page_color": "#000000",
        "page_top": 0,
        "show_title": true,
        "title": "<p><strong>Response Is</strong> Everything</p>",
        "title_font": "rushblade",
