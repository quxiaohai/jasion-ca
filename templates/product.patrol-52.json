    "large_header_slider_hb_jHEfnU": {
      "type": "large-header-slider-hb",
      "blocks": {
        "item_8NiF9n": {
          "type": "item",
          "settings": {
            "img_1": "shopify://shop_images/1_37194af7-6f4a-44a4-9290-946053541318.jpg",
            "tab_con": "Establishment",
            "tab_con_font": "rushblade",
            "title": "Born to Redefine the Ride",
            "content": "The Patrol was conceived with one mission: to dominate beyond the pavement.\n\nEngineered from the ground up to redefine expectations, it merges motorcycle-grade power with the agility and freedom of an eBike—built for rugged trails and high-performance riding. Every detail, from its aggressive powertrain to off-road-focused geometry, is purpose-built for the wild."
          }
        },
        "item_xybDjj": {
          "type": "item",
          "settings": {
            "img_1": "shopify://shop_images/2_4420e5c8-1223-4842-81d8-2b0d963d3031.jpg",
            "tab_con": "Design",
            "tab_con_font": "rushblade",
            "title": "Tame the Terrain",
            "content": "At the core of Patrol’s design is a full-terrain philosophy. Its full suspension system (soft-tail architecture) absorbs aggressive impacts while maintaining stability and rider confidence across dirt, gravel, and uneven terrain.\n\nEngineered for explosive yet controlled performance, the 4000W motor delivers 145Nm of torque, launching from 0 to 20 mph in just 3.5 seconds. Wide fat tires enhance grip and stability, while NFC unlocking adds seamless, keyless convenience—ensuring every detail serves both performance and rider ease."
          }
        },
        "item_rrJjJL": {
          "type": "item",
          "settings": {
            "img_1": "shopify://shop_images/3_6ac2d67b-dea2-4d78-b179-3c6f1a677563.jpg",
            "tab_con": "Craftsmanship",
            "tab_con_font": "rushblade",
            "title": "Precision in Every Detail",
            "content": "Patrol’s craftsmanship is built on durability, precision, and advanced engineering. Its 52V 30Ah battery delivers extended range with efficient performance, while fast charging (15% to 80% in 3.5 hours) reduces downtime.\n\nHydraulic brakes provide reliable stopping power, enhanced by integrated brake lighting for added visibility. From suspension tuning to electronic integration, every component is refined to perform in demanding, real-world conditions."
          }
        },
        "item_KhV99j": {
          "type": "item",
          "settings": {
            "img_1": "shopify://shop_images/4_4d638ab9-3083-412f-b00c-4907c75d29f4.jpg",
            "tab_con": "Finished Product",
            "tab_con_font": "rushblade",
            "title": "Street legal. Trail ready. No compromises.",
            "content": "Patrol represents a new category of riding—where regulation meets rebellion. Designed to comply with road standards while carrying the DNA of an off-road machine, it delivers a rare balance of control, capability, and freedom."
          }
        }
      },
