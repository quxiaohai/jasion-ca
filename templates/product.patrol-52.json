    "mc_media_image": {
      "type": "mc_media-image",
      "settings": {
        "page_color": "#000000",
        "page_top": 0,
        "show_title": true,
        "title": "<p><strong>Response Is</strong> Everything</p>",
        "title_font": "rushblade",
        "title_pc_size": 75,
        "title_pc_weight": 400,
        "title_pc_line": 110,
        "title_mb_size": 24,
        "title_mb_weight": 700,
        "title_mb_line": 120,
        "title_margin_bottom": 16,
        "title_color": "#ffffff",
        "title_bold_color": "#ffe500",
        "title_gradient_color": "",
        "show_description": true,
        "description": "<p>The Patrol electric bike features a high-performance motor with up to 4000W peak power and 145 Nm of torque, delivering powerful acceleration and outstanding climbing ability. It sprints from 0–20 mph in just 3.5 seconds, giving you instant power for steep hills and rugged dirt trails.</p>",
        "description_color": "#ffffff",
        "description_bold_color": "#000000",
        "description_pc_size": 18,
        "description_pc_line": 120,
        "description_mb_size": 14,
        "description_mb_line": 120,
