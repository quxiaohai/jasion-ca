        "description_mb_margin_bottom": 30,
        "pc_image": "shopify://shop_images/banner2_7627b000-84d9-439b-aaae-446e210ac836.png",
        "mb_image": "shopify://shop_images/banner2-YD_a7585fff-dc7a-457c-ae1c-61ed057341bb.png",
