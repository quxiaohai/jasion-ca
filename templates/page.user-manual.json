      "blocks": {
        "video_TMpMtQ": {
          "type": "video",
          "settings": {
            "video_url": "https://www.youtube.com/watch?v=ON-qwVUzTRo",
            "description": "",
            "enable_video_autoplay": false,
            "enable_video_looping": false,
            "image_height": "adapt",
            "video_url_mobile": "https://www.youtube.com/watch?v=ON-qwVUzTRo",
            "image_height_mobile": "auto",
            "date": "",
            "title": "Jasion App Quick Start Guide",
            "title_sz": "h5",
            "content": "The Jasion App is a powerful tool that puts the full capabilities of your Jasion ebike right at your fingertips. It offers a seamless and intuitive way to customize your ride, record your progress, and stay connected with the Jasion community. Let's take a closer look at what the app offers.",
            "author": ""
          }
        },
        "video_TH8hik": {
          "type": "video",
          "settings": {
            "video_url": "https://www.youtube.com/watch?v=OjOLswqdTX0",
            "description": "",
            "enable_video_autoplay": false,
            "enable_video_looping": false,
            "image_height": "adapt",
            "video_url_mobile": "",
            "image_height_mobile": "auto",
            "date": "",
            "title": "X-Hunter Adjusting to Maximum Speed (30MPH+)",
            "title_sz": "h5",
            "content": "Here is a solution to address the issue of customers unable to reach 30 miles per hour.<br><br>\n\nHere are the steps:<br><br>\n\n1- You'll need to access the settings page on the display. (To access this page, press and hold both the up and down keys for 3 seconds.)<br>\n2- Press the M key to navigate to page P08. You'll notice a number displayed below. The smaller the number, the slower the speed; the larger the number, the faster the speed. The number range is 0-100. To achieve the highest speed, adjust the number to 100.",
            "author": "RVdaydream"
          }
        },
        "video_YXW9Vk": {
          "type": "video",
          "settings": {
            "video_url": "https://www.youtube.com/watch?v=hE6QEso7IaA",
            "description": "",
            "enable_video_autoplay": false,
            "enable_video_looping": false,
            "image_height": "adapt",
            "video_url_mobile": "",
            "image_height_mobile": "auto",
            "date": "",
            "title": "X-Hunter Adjusting PAS from PAS3 to PAS5",
            "title_sz": "h5",
            "content": "Here is a solution to address the issue raised by a customer regarding the PAS (Pedal Assist System) having only 3 levels. <br><br>\nHere are the steps:<br><br>\n\n1- Access the settings page on the display. (To access this page, press and hold both the up and down keys for 3 seconds.)<br>\n2- Press the M key to navigate to page P05. Check if the number below shows as 1. If it displays as 0, press the up key to change it to 1. A value of 0 corresponds to 3 levels, while a value of 1 corresponds to 5 levels.<br>\n*PAS refers to the Pedal Assist System.",
            "author": "RVdaydream"
          }
        }
      },
