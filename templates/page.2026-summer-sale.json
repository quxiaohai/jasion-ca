    "autumn_sale_says_9RUVcG": {
      "type": "autumn-sale-says",
      "blocks": {
        "say_Bd33R8": {
          "type": "say",
          "settings": {
            "intro": "<p>If you're more concerned about safety than commute distance, you'll enjoy the front fork suspension, front and rear mechanical disc brakes, and more.</p>",
            "image_icon": "shopify://shop_images/17_c7a32e0e-d33f-406e-a52e-077060f12ea3.jpg"
          }
        },
        "say_nbxpaR": {
          "type": "say",
          "settings": {
            "intro": "<p>Users enjoy the long battery life and smooth ride. They also like the compact design, which works well for city commuting. The user-friendly controls make day-to-day operations simple and efficient.</p>",
            "image_icon": "shopify://shop_images/1_2a200d81-f781-46f2-8779-b9ddb93f59b8.jpg"
          }
        },
        "say_zGMMxf": {
          "type": "say",
          "settings": {
            "intro": "<p>Don't worry about riding at night as this bike has bright LED headlights, rear reflectors and reflective strips on the tires so you'll be seen even in the dark.</p>",
            "image_icon": "shopify://shop_images/10_02caecc6-8216-4f34-8d7c-2a448a000a7c.jpg"
          }
        },
        "say_p8cfKf": {
          "type": "say",
          "settings": {
            "intro": "<p>This fat tire bike has everything you need to take on your next adventure: integrated lights, shock-absorption fat tires, and a lightning-quick twist throttle for a boost.</p>",
            "image_icon": "shopify://shop_images/9_d78ce27d-5d1a-430e-80be-2f00617dc1e6.jpg"
          }
        }
      },
      "block_order": [
        "say_Bd33R8",
        "say_nbxpaR",
        "say_zGMMxf",
        "say_p8cfKf"
      ],
