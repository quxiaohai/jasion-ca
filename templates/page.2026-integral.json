    "mc_main_faq_Ykt3jq": {
      "type": "mc_main-faq",
      "blocks": {
        "faq_YatDyD": {
          "type": "faq",
          "settings": {
            "title": "Jasion Membership Program",
            "default_open_1": "Yes",
            "title_1": "1. What's the JASION Membership Program?",
            "answer_1": "<p>It’s our rewards program designed for JASION riders. Earn points when you shop or complete simple activities, then redeem them for discounts, rewards, and exclusive member perks. As you level up, you’ll unlock even more benefits like special offers, early access, and VIP rewards.</p>",
            "default_open_2": "No",
            "title_2": "2. How to join?",
            "answer_2": "<p>Simply create a JASION account, and you’ll automatically become a member and start earning rewards.</p>",
            "default_open_3": "No",
            "title_3": "3. Is the rewards program free?",
            "answer_3": "<p>Absolutely — joining is completely free.</p>",
            "default_open_4": "No",
            "title_4": "4. What are the tiers of this program?",
            "answer_4": "<p>There are 3 membership tiers: Trailblazer, Pathfinder, and Peak Rider. Your tier updates automatically 30 days after delivery of a qualifying order. See the Membership Program page for full details.</p>",
            "default_open_5": "No",
            "title_5": "5. How can I check my account details?",
            "answer_5": "<p>Log into your JASION account to view your points balance, rewards, membership tier, and account activity anytime.</p>",
            "default_open_6": "No",
            "title_6": "",
            "answer_6": "",
            "default_open_7": "No",
            "title_7": "",
            "answer_7": "",
            "default_open_8": "No",
