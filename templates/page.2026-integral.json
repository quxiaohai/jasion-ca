        "faq_EAhfAB": {
          "type": "faq",
          "settings": {
            "title": "Jasion Bucks",
            "default_open_1": "Yes",
            "title_1": "1. Do points expire?",
            "answer_1": "<p>Yes. Points expire after 12 months of inactivity.</p>",
            "default_open_2": "No",
            "title_2": "2. How do I check my points balance?",
            "answer_2": "<p>Log into your account to view your balance and rewards.</p>",
            "default_open_3": "No",
            "title_3": "3. When will I receive my points?",
            "answer_3": "<p>Your points will be added automatically 30 days after your order is paid.</p>",
            "default_open_4": "No",
            "title_4": "4. Can I earn JASION Bucks if I purchase on other platforms?",
            "answer_4": "<p>Currently, points can only be earned on purchases made through the official Jasion website. Orders placed through other platforms or marketplaces are not eligible for rewards points.</p>",
            "default_open_5": "No",
            "title_5": "5.  What happens to my JASION Bucks if I return the product or cancel my order?",
            "answer_5": "<p>If an order is canceled or refunded, the points earned from that purchase will be automatically removed from your account balance.</p>",
            "default_open_6": "No",
            "title_6": "6. What doesn't qualify for Bucks?",
            "answer_6": "<p>Points are not earned on canceled orders, refunded purchases, shipping fees, taxes, gift cards, or orders placed through third-party platforms.</p>",
            "default_open_7": "No",
            "title_7": "",
            "answer_7": "",
            "default_open_8": "No",
