    "faq_ehwjkn": {
      "type": "faq",
      "blocks": {
        "question_pMRV47": {
          "type": "question",
          "settings": {
            "title": "1. What's your shipping policy?",
            "title_tag": "span",
            "text": "<p>Jasion has suspended local pick-up services in the United States. If pick-up services are resumed, we will update the information on our website. Please check the website for updates.</p><p>We provide UPS, USPS, and FedEx shipping services.  We DO NOT ship to PO BOXES.</p><p>In-stock orders typically ship within 2 business days, unless otherwise noted on the product page. Please allow 5-7 business days for your shipment to arrive at your address. Any delivery dates provided by JASION are estimates.</p><p>For more shipping information, send an email to support@Jasionbike.com. We will get back to you in 24 hours.</p><p>Want to know more about shipping policies, please check more details on our <a href=\"https://www.jasionbike.com/pages/shipping-policy\" title=\"https://www.jasionbike.com/pages/shipping-policy\">Shipping Policy Page</a>.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_A7Ucqc": {
          "type": "question",
          "settings": {
            "title": "2. What's your warranty policy?",
            "title_tag": "span",
            "text": "<p>All JASION bikes carry a one(1) year warranty from the date of receipt of the bike for manufacturing defects in materials and/or workmanship( all free accessories are not covered).<br/><br/>We will replace any component that is defective or damaged in materials and/or workmanship( including the damage in the processing of shipment).<br/><br/>Before making a warranty claim, we suggest that you first contact us at <strong>support@jasionbike.com</strong>.</p><p>Want to know more about warranty policies, please check more details on our <a href=\"/pages/warranty\" title=\"Warranty\">Warranty Policy Page</a>.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_yBbHQE": {
          "type": "question",
          "settings": {
            "title": "3. What's your return&refund policy?",
            "title_tag": "span",
            "text": "<p>We provide exchange service within 14 days. If the product is defective or damaged, Send damaged photos or videos to customer service within 14 days after receiving the goods, and the damaged parts can be replaced or compensated. We will cover the return (exchange) shipping costs.</p><p>In the case of non-quality returns, the customer will be responsible for the return shipping costs.</p><p>You can always contact us for any return questions at <strong>support@jasionbike.com</strong>.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_gPd36L": {
          "type": "question",
          "settings": {
            "title": "4. Does my height suit Thunder Pro?",
            "title_tag": "span",
            "text": "<p>The recommended rider height is 5'5\" to 7'2\".</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_7mHYL9": {
          "type": "question",
          "settings": {
            "title": "5. How long does it take to fully charge the battery?",
            "title_tag": "span",
            "text": "<p>It will take 7-8 hours.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_rDpyRx": {
          "type": "question",
          "settings": {
            "title": "6. How long will it take for my shipment to arrive?",
            "title_tag": "span",
            "text": "<p>Generally, your order will be shipped within one business day after the order is placed, and package shipping will take approximately 3-5 days.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_zU9TB9": {
          "type": "question",
          "settings": {
            "title": "7. Does my Jasion ebike come pre-assembled?",
            "title_tag": "span",
            "text": "<p>Your e-bike arrives 85% assembled. There are just a few pieces to put into place once you take the bike out of the box. For unboxing and setup instructions, please follow the guides on our <a href=\"https://www.youtube.com/watch?v=i0LcsKoZaXU\" target=\"_blank\" title=\"https://www.youtube.com/watch?v=i0LcsKoZaXU\">YouTube Channel</a>.</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "question_iUtT7w": {
          "type": "question",
          "settings": {
            "title": "8. What is the maximum speed of each PAS level?",
            "title_tag": "span",
            "text": "<p>PAS1 Top speed 16mph</p><p>PAS2 Top speed 18mph</p><p>PAS3 Top speed 20mph</p><p>PAS4 Top speed 28mph</p><p>PAS5 Top speed 35mph</p>",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        }
      },
