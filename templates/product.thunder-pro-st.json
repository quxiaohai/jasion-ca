    "multicolumn_slide_hb_dfCJ6M": {
      "type": "multicolumn-slide-hb",
      "blocks": {
        "item_UK9pgA": {
          "type": "item",
          "settings": {
            "img": "shopify://shop_images/1_38a23cf4-dd97-4587-b93a-b8ab61c503ab.jpg",
            "date": "",
            "title": "26\" x 4\" Puncture-Resistant Tires",
            "title_sz": "h4",
            "content": "26×4 fat tires deliver superior grip and stability, floating smoothly over snow, sand, and rough terrain—so you ride with more control and confidence in any condition.",
            "author": ""
          }
        },
        "item_6NEbTP": {
          "type": "item",
          "settings": {
            "img": "shopify://shop_images/9APP_b73ff428-c9fc-4a14-b301-2113c305b57a.jpg",
            "date": "",
            "title": "Connect. Ride. Explore.",
            "title_sz": "h4",
            "content": "Monitor your battery, track rides, customize settings, and plan routes all from your phone. Stay connected for a smoother ride.",
            "author": ""
          }
        },
        "item_qzYw3y": {
          "type": "item",
          "settings": {
            "img": "shopify://shop_images/3_97cd7505-3eeb-40f0-8f49-062e165d13fe.jpg",
            "date": "",
            "title": "Shimano 7-Speed",
            "title_sz": "h4",
            "content": "With the Shimano 7-speed drivetrain and motorcycle-style hand-twist throttle, enjoy smooth shifting and effortless control, whether you're accelerating, climbing, or cruising.",
            "author": ""
          }
        },
        "item_pQPKcj": {
          "type": "item",
          "settings": {
            "img": "shopify://shop_images/5_41244bbf-3114-45d4-9e52-53bac1e90d4d.jpg",
            "date": "",
            "title": "Headlight&Taillight",
            "title_sz": "h4",
            "content": "The high-brightness headlight lights the road in low-visibility conditions, the brake light activates instantly when you pull the lever, and built-in turn signals clearly show your direction.",
            "author": ""
          }
        },
        "item_aLYEqM": {
          "type": "item",
          "settings": {
            "img": "shopify://shop_images/7_15fc573c-cead-434c-9b2a-674568dfb695.jpg",
            "date": "",
            "title": "Haul More, Ride Ready",
            "title_sz": "h4",
            "content": "The durable rear rack enhances versatility, making it perfect for carrying groceries, outdoor gear, or even an extra passenger. It easily fits bags, cargo boxes, and pet carriers—ready to ride.（Standard tail bag included）",
            "author": ""
          }
        },
        "item_mtV8h7": {
          "type": "item",
          "settings": {
            "img": "shopify://shop_images/8_d3756e42-5b3c-4f1b-851e-7e75567e6d23.jpg",
            "date": "",
            "title": "Color Display",
            "title_sz": "h4",
            "content": "Displays critical ride data like speed, battery life, and mileage, with excellent visibility in all light conditions",
            "author": ""
          }
        },
        "item_EVD96X": {
          "type": "item",
          "settings": {
            "img": "shopify://shop_images/10_ed7a179f-bef1-4c22-9271-8bb8e4fc7540.jpg",
            "date": "",
            "title": "Extra-Comfort Saddle",
            "title_sz": "h4",
            "content": "Thunder Pro features an ergonomically designed, thickened saddle with high-resilience padding that provides lasting comfort and absorbs bumps from rough terrain.",
            "author": ""
          }
        }
      },
