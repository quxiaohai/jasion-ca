    "image_with_text_4jnJkP": {
      "type": "image-with-text",
      "blocks": {
        "heading_gmXXwx": {
          "type": "heading",
          "settings": {
            "heading": "<p>Master Every Trail. Own the Ride.</p>",
            "heading_size": "title-sm",
            "heading_tag": "h2",
            "highlighted_text": "none",
            "highlighted_scribble": "circle"
          }
        },
        "text_GtepjG": {
          "type": "text",
          "settings": {
            "text": "<p>Thunder Pro ST’s upgraded motor delivers 1200W of sustained power, peaking at 2000W, with an impressive 115 N·m of torque to take on steep climbs and rough terrain with ease. Accelerate from 0–20 mph in just 5 seconds, enjoying strong, responsive power that keeps every ride smooth, controlled, and effortlessly confident.</p>",
