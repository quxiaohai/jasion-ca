          "settings": {
            "img_1": "shopify://shop_images/3_2ce2fdff-506f-445f-830f-7ac09619bed4.jpg",
            "tab_con": "Craftsmanship",
            "tab_con_font": "",
            "title": "Precision in Every Detail",
            "content": "Thunder Pro is built with precision and purpose. From its hydraulic disc brakes for confident stopping to its front and rear suspension system designed to absorb impacts and rough terrain, every component is selected and assembled to endure demanding conditions. Attention to detail in materials, welding, and component integration ensures strength, durability, and long-term reliability."
          }
        },
