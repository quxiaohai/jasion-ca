<style>
    #MainContent {
    {%- if section.settings.background_image != blank -%}
        background: url('{{ section.settings.background_image | image_url: width: 1920 }}') repeat-y {{ section.settings.background_color }};
        background-size: 100% auto;
    {%- else -%}
        background: {{ section.settings.background_color }} !important;
    {%- endif -%}
    }

    [role="main"] .shopify-section:not(.shopify-section--apps) {
        background: none;
    }
</style>
{% schema %}
{
  "name": "MC Page Color",
  "class": "mc--main",
  "tag": "section",
  "presets": [
    {
      "name": " MC Page Color"
    }
  ],
  "settings": [
    {
      "type": "color",
      "label": "Background color",
      "id": "background_color",
      "default": "#790002"
    },
    {
      "type": "image_picker",
      "label": "Background image",
      "id": "background_image"
    }
  ]
}
{% endschema %}