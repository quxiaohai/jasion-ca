    {
      "label": "Mobile after image",
      "type": "image_picker",
      "id": "mb_after_image_url"
    },
    {
      "type": "range",
      "id": "mb_image_radius",
      "label": "Mobile image radius",
      "min": 0,
      "max": 80,
      "step": 1,
      "unit": "dug",
      "default": 8
    },
    {
      "type": "range",
      "id": "mb_image_width",
      "label": "Mobile image width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
