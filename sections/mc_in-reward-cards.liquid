{%- assign ss = section.settings -%}
<style>
    .mc_in-reward-cards {
        padding: 80px 0;
        background-color: #ffffff;
    }

    .mc_in-reward-cards .card-items {
        gap: 25px;
    }

    .mc_in-reward-cards .card-item .image {
        width: 338px;
        height: 340px;
        border-radius: 16px;
    }

    .mc_in-reward-cards .card-item .name {
        padding-top: 24px;
        font-size: 20px;
        color: #000000;
    }

    @media screen and (max-width: 1023px) {
        .mc_in-reward-cards {
            padding: 1.5625rem 0;
        }

        .mc_in-reward-cards .card-items {
            gap: 0.87890625rem;
            overflow-x: auto;
            justify-content: flex-start;
            padding: 0 0.80078125rem;
        }

        .mc_in-reward-cards .card-item .image {
            width: 11.8359375rem;
            min-width: 50.5vw;
            height: 11.89453125rem;
            border-radius: 0.3125rem;
        }

        .mc_in-reward-cards .card-item .name {
            padding-top: 0.8203125rem;
            font-size: 0.78125rem;
        }
    }

    {% render 'page-wrap-style' %}
</style>
<div class="mc_in-reward-cards section--page">
    {%- render 'section-title', info: ss -%}
    <div class="card-items hide-scroll-bar flex-center">
        {%- for block in section.blocks -%}
            {%- assign bs = block.settings -%}
            <div class="card-item">
                {%- render 'global-image',
                    desktop_img: bs.image,
                    desktop_size: 400,
                    mobile_img: bs.mb_image,
                    mobile_size: 600,
                    preload: ss.image_preload
                -%}
                <div class="name text-center fw-700">{{ bs.title }}</div>
            </div>
        {%- endfor -%}
    </div>
</div>
{% schema %}
{
  "name": "MC In Reward Cards",
  "class": "mc--main",
  "tag": "section",
  "presets": [
    {
      "name": "MC In Reward Cards"
    }
  ],
  "settings": [
    {
      "type": "color",
      "id": "page_color",
      "label": "Background Color"
    },
    {
      "type": "number",
      "id": "page_top",
      "label": "Padding Top"
    },
    {
      "type": "number",
      "id": "page_bottom",
      "label": "padding Bottom"
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show Title",
      "default": true
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Title",
      "default": "<p>Redeem Your Rewards</p>"
    },
    {
      "type": "text",
      "id": "font_name",
      "label": "Font name"
    },
    {
      "type": "select",
      "id": "title_style",
      "label": "Title font style",
      "options": [
        {
          "label": "Normal",
          "value": "normal"
        },
        {
          "label": "italic",
          "value": "italic"
        }
      ],
      "default": "normal"
    },
    {
      "type": "range",
      "id": "title_pc_size",
      "label": "Desktop title size",
      "min": 12,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "title_mb_size",
      "label": "Mobile title size",
      "min": 6,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "number",
      "id": "title_margin_bottom",
      "label": "Desktop title margin bottom",
      "default": 16
    },
    {
      "type": "number",
      "id": "title_mb_margin_bottom",
      "label": "Mobile title margin bottom",
      "default": 16
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "title_bold_color",
      "label": "Title Bold color",
      "default": "#ffffff"
    },
    {
      "type": "color_background",
      "id": "title_gradient_color",
      "label": "Title gradient color"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show description",
      "default": false
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "description_pc_size",
      "label": "Desktop description size",
      "min": 12,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "description_mb_size",
      "label": "Mobile description size",
      "min": 6,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "number",
      "id": "description_pc_margin_bottom",
      "label": "Desktop description margin bottom",
      "default": 40
    },
    {
      "type": "number",
      "id": "description_mb_margin_bottom",
      "label": "Mobile description margin bottom",
      "default": 30
    },
    {
      "type": "header",
      "content": "Card"
    },
    {
      "type": "color",
      "id": "card_title_color",
      "label": "Card title color",
      "default": "#000000"
    },
    {
      "type": "checkbox",
      "id": "image_preload",
      "label": "Image preload",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Card",
      "limit": 3,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Desktop image"
        },
        {
          "type": "image_picker",
          "id": "mb_image",
          "label": "Mobile image"
        },
        {
          "type": "richtext",
          "id": "title",
          "label": "Title",
          "default": "<p>COUPONS</p>"
        }
      ]
    }
  ]
}
{% endschema %}
