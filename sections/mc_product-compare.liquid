{% assign ss = section.settings %}
<style>
    .mc_product-compare {
        padding: 80px 0;
        background: #ffffff;
    }

    .mc_product-compare .compare-content {
        margin: 0 auto;
        width: auto;
        max-width: 1318px;
        --max-width: 275px;
    }

    .mc_product-compare .compare-content.sticky {
        position: sticky;
        transition: top var(--animation-nav);
        background-color: #ffffff;
        z-index: 2;
        overflow: hidden;
    }

    .mc_product-compare .compare-content .product-items {
        width: 100%;
        align-items: start;
        padding-left: 215px;
        padding-bottom: 6px;
    }

    .mc_product-compare .compare-content .product-items .product-item {
        width: var(--max-width);
    }

    .mc_product-compare .compare-content .product-items .product-item .cover {
        width: 162px;
        height: 139px;
        margin-left: 24px;
    }

    .mc_product-compare .compare-content .product-items .product-item .cover .image {
        object-fit: contain;
    }

    .mc_product-compare .compare-content .product-items .product-item .info {
        align-items: flex-start;
        padding-left: 24px;
    }

    .mc_product-compare .compare-content .product-items .product-item .bike-title {
        padding-top: 6px;
        font-size: 20px;
        font-weight: bold;
        line-height: 1.2;
        color: #000000;
    }

    .mc_product-compare .compare-content .product-items .product-item .variant-selects {
        width: 100%;
        padding-top: 10px;
    }

    .mc_product-compare .compare-content .product-items .product-item .variant-selects .color-items {
        gap: 10px;
        padding-bottom: 6px;
    }

    .mc_product-compare .compare-content .product-items .product-item .variant-selects .color-items .color-item {
        width: 26px;
        height: 26px;
    }

    .mc_product-compare .compare-content .product-items .product-item .variant-selects .color-items .color-item .color-swatch {
        --swatch-size: 20px;
        --swatch-radius: 4px;
    }

    .mc_product-compare .compare-content .product-items .product-item .variant-selects ._dropdown-root {
        position: relative;
        min-height: 46px;
        width: 100%;
    }

    .mc_product-compare .compare-content .product-items .product-item .variant-selects ._dropdown-wrap {
        width: 90%;
        min-height: 46px;
        position: absolute;
        left: 0;
        top: 0;
        z-index: 3;
        overflow: hidden;
    }

    .mc_product-compare .compare-content .product-items .product-item .variant-selects ._dropdown-wrap.on {
        z-index: 4;
    }

    .mc_product-compare .compare-content .product-items .product-item .variant-selects ._dropdown-wrap.on ._drop-info {
        z-index: 3;
    }

    .mc_product-compare .compare-content .product-items .product-item .variant-selects ._dropdown-wrap.on ._drop-info .arrow-down {
        transform: rotate(180deg);
    }

    .mc_product-compare .compare-content .product-items .product-item .variant-selects ._dropdown-wrap.on ._drop-items {
        display: block;
        z-index: 2;
        width: auto;
    }

    .mc_product-compare .compare-content .product-items .product-item .variant-selects ._dropdown-wrap ._drop-items {
        border: 1px solid #999999;
        border-radius: 12px;
        box-sizing: border-box;
        background-color: #ffffff;
        position: relative;
    }

    .mc_product-compare .compare-content .product-items .product-item .variant-selects ._dropdown-wrap ._drop-info {
        height: 40px;
        width: auto;
        max-width: 230px;
        cursor: pointer;
    }

    .mc_product-compare .compare-content .product-items .product-item .variant-selects ._dropdown-wrap ._drop-info .drop-text {
        font-size: 16px;
        color: #000000;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
        padding-right: 12px;
    }

    .mc_product-compare .compare-content .product-items .product-item .variant-selects ._dropdown-wrap ._drop-info .arrow-down {
        width: 20px;
        height: 20px;
        transition: all 0.5s;
    }

    .mc_product-compare .compare-content .product-items .product-item .variant-selects ._dropdown-wrap ._drop-info .arrow-down .svg-img {
        width: 100%;
        height: 100%;
    }

    .mc_product-compare .compare-content .product-items .product-item .variant-selects ._dropdown-wrap .scroll-view {
        -webkit-overflow-scrolling: touch;
        overflow: auto;
        max-height: 180px;
        width: 100%;
    }

    .mc_product-compare .compare-content .product-items .product-item .variant-selects ._dropdown-wrap ._drop-items {
        display: none;
        padding: 12px 0;
        overflow: hidden;
    }

    .mc_product-compare .compare-content .product-items .product-item .variant-selects ._dropdown-wrap ._drop-items .drop-item {
        min-height: 32px;
        line-height: 1.2;
        font-weight: 400;
        font-size: 14px;
        color: #333333;
        word-break: break-word;
        padding: 6px 22px;
        box-sizing: border-box;
        cursor: pointer;
        white-space: normal;
        transition: background-color 0.5s ease-in-out;
    }

    .mc_product-compare .compare-content .product-items .product-item .variant-selects ._dropdown-wrap ._drop-items .drop-item:hover {
        background-color: rgba(255, 241, 104, 0.5);
    }

    .mc_product-compare .compare-content .product-items .product-item .variant-selects ._dropdown-wrap ._drop-items .drop-item.selected {
        background-color: #fff168;
    }

    .mc_product-compare .compare-content .compare-box {
        padding: 22px 0;
        border-bottom: 1px solid #d7d7d7;
    }

    .mc_product-compare .compare-content .compare-box.first {
        border-top: 1px solid #d7d7d7;
    }

    .mc_product-compare .compare-content .compare-box .title {
        font-size: 20px;
        line-height: 1.2;
        font-weight: 700;
        color: #000000;
        width: 215px;
    }

    .mc_product-compare .compare-content .compare-box .info-items .info-item {
        width: var(--max-width);
        padding-left: 24px;
    }

    .mc_product-compare .compare-content .compare-box .info-items .info-item .text {
        font-size: 20px;
        line-height: 1.2;
        color: #6e6e6e;
    }

    .mc_product-compare .compare-content .compare-box .info-items .info-item .text strong,
    .mc_product-compare .compare-content .compare-box .info-items .info-item .text b {
        font-weight: bold;
    }

    @media screen and (max-width: 1440px) {
        .mc_product-compare {
            padding: 64px 0;
        }

        .mc_product-compare .compare-content {
            --max-width: 19.097vw;
        }

        .mc_product-compare .compare-content .product-items {
            padding-left: 172px;
            padding-bottom: 5px;
        }

        .mc_product-compare .compare-content .product-items .product-item .cover {
            width: 130px;
            height: 111px;
            margin-left: 19px;
        }

        .mc_product-compare .compare-content .product-items .product-item .info {
            padding-left: 19px;
        }

        .mc_product-compare .compare-content .product-items .product-item .bike-title {
            padding-top: 5px;
            font-size: 16px;
        }

        .mc_product-compare .compare-content .product-items .product-item .variant-selects {
            padding-top: 8px;
        }

        .mc_product-compare .compare-content .product-items .product-item .variant-selects ._dropdown-root {
            min-height: 37px;
        }

        .mc_product-compare .compare-content .product-items .product-item .variant-selects ._dropdown-wrap {
            min-height: 37px;
        }

        .mc_product-compare .compare-content .product-items .product-item .variant-selects ._dropdown-wrap ._drop-items {
            border-radius: 10px;
        }

        .mc_product-compare .compare-content .product-items .product-item .variant-selects ._dropdown-wrap ._drop-info {
            height: 32px;
            max-width: 184px;
        }

        .mc_product-compare .compare-content .product-items .product-item .variant-selects ._dropdown-wrap ._drop-info .drop-text {
            font-size: 13px;
            padding-right: 10px;
        }

        .mc_product-compare .compare-content .product-items .product-item .variant-selects ._dropdown-wrap ._drop-info .arrow-down {
            width: 16px;
            height: 16px;
        }

        .mc_product-compare .compare-content .product-items .product-item .variant-selects ._dropdown-wrap .scroll-view {
            max-height: 144px;
        }

        .mc_product-compare .compare-content .product-items .product-item .variant-selects ._dropdown-wrap ._drop-items {
            padding: 10px 0;
        }

        .mc_product-compare .compare-content .product-items .product-item .variant-selects ._dropdown-wrap ._drop-items .drop-item {
            min-height: 26px;
            font-size: 12px;
            padding: 5px 18px;
        }

        .mc_product-compare .compare-content .compare-box {
            padding: 18px 0;
        }

        .mc_product-compare .compare-content .compare-box .title {
            font-size: 16px;
            width: 172px;
        }

        .mc_product-compare .compare-content .compare-box .info-items .info-item {
            padding-left: 19px;
        }

        .mc_product-compare .compare-content .compare-box .info-items .info-item .text {
            font-size: 16px;
        }
    }

    @media screen and (max-width: 1023px) {
        .mc_product-compare {
            padding: 1.624959376rem 0;
