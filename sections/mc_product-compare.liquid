            margin-left: 0.914039649rem;
        }

        .mc_product-compare .compare-content .product-items .product-item .info {
            padding-left: 0.914039649rem;
        }

        .mc_product-compare .compare-content .product-items .product-item .bike-title {
            padding-top: 0.2437439064rem;
