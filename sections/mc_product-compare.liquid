        }
    }
</style>
<section class="mc_product-compare">
    {% render 'section-title', info: ss %}
    <div class="compare-content hide-scroll-bar flex-center-col sticky" id="{{ section.id }}-compare">
        <div class="product-items flex-center" node-name="productWrap">
            {%- for block in section.blocks -%}
                {%- liquid
                    assign bs = block.settings
                    assign type = block.type
                -%}
                {%- if bs.product != blank  -%}
                    {%- assign variant = bs.product.selected_or_first_available_variant -%}
                    <div class="product-item">
                        <a href="{{ bs.product.url }}" class="cover relative flex-center" node-name="cover">
                            {% render 'global-image',
                                desktop_img: variant.featured_image,
                                desktop_size: 400
                            %}
                        </a>
                        <div class="info flex-center-col">
                            <div class="bike-title">{{ bs.product.title }}</div>
                            <div class="variant-selects">
                                <div node-name="color"></div>
                                <div node-name="variant"></div>
                            </div>
                        </div>
                    </div>
                {%- elsif type == 'other_product' -%}
                    <div class="product-item">
                        <a href="{% if  bs.url != blank %}{{ bs.url }}{% else %}javascript:void(0){% endif %}" class="cover relative flex-center" node-name="cover">
                            {% render 'global-image',
                                desktop_img: bs.image1,
                                desktop_size: 400
                            %}
                        </a>
                        <div class="info flex-center-col">
                            <div class="bike-title">{{ bs.title }}</div>
                            <div class="variant-selects">
                                <div node-name="color"></div>
                                <div node-name="variant"></div>
                            </div>
                        </div>
                    </div>
                {%- endif -%}
            {%- endfor -%}
        </div>
    </div>
    <div class="compare-content hide-scroll-bar flex-center-col" id="{{ section.id }}-scroll">
        {%- assign title_list = ss.compare_title | newline_to_br | split: '<br />' -%}
        {%- for title in title_list -%}
            {%- assign index = forloop.index0 -%}
            <div class="compare-box flex-top{% if forloop.first %} first{% endif %}">
                <div class="title">
                    {{ title | strip }}
                </div>
                <div class="info-items flex-top">
                    {%- for block in section.blocks -%}
                        {%- assign bs = block.settings -%}
                        {%- if bs.product != blank or block.type == 'other_product' -%}
                            {%- assign param_list = bs.product_params | newline_to_br | split: '<br />' -%}
                            <div class="info-item">
                                <div class="text">{{ param_list[index] | strip }}</div>
                            </div>
                        {%- endif -%}
                    {%- endfor -%}
                </div>
            </div>
        {%- endfor -%}
    </div>
</section>
<script>
    (function () {
        const node = document.getElementById('{{ section.id }}-compare');
        const elemScroll = document.getElementById('{{ section.id }}-scroll');
        const nodeList = $heybike.getNodeList(node);
        const elemCovers = [].concat(nodeList.cover);
        const elemColors = [].concat(nodeList.color);
        const elemVariants = [].concat(nodeList.variant);
        let index = 10000;
        const getUid = () => {
            return index++;
        }
        const productList = [
            {%- for block in section.blocks -%}
            {%- liquid
                assign bs = block.settings
                assign type = block.type
            -%}
            {%- if bs.product != blank or type == 'other_product' -%}
            {
                cIndex: 0,
                vIndex: 0,
                id: `{% if type == 'other_product' %}${getUid()}{% else %}{{ bs.product.id }}{% endif %}`,
                variants: [
                    {%- if type == 'other_product' -%}
                    {%- for v in (1..5) -%}
                    {%- liquid
                        assign img = 'image' | append: v
                        assign color = 'color' | append: v
                        assign text = 'text' | append: v
                    -%}
                    {%- if bs[img] != blank and bs[color] != blank -%}
                    {
                        id: `${getUid()}`,
                        key: "{{ bs[text] | handleize }}",
                        color: "{{ bs[color] }}",
                        color_image: "",
                        value: "{{ bs[text] }}",
                        image: "{{ bs[img] | image_url: width: 650 }}"
                    },
                    {%- endif -%}
                    {%- endfor -%}
                    {%- else -%}
                    {%- liquid
                        assign options_size = bs.product.options_with_values.size
                        assign option = bs.product.options_with_values[0]
                    -%}
                    {%- for value in option.values -%}
                    {%- assign option_value = value | escape -%}
                    {%- if options_size > 1 -%}
                    {
                        {% render 'color-object', value: value %}
                        value: "{{ option_value }}",
                        key: "{{ value | handleize }}",
                        childList: [
                            {%- for variant in bs.product.variants -%}
                            {%- if variant.option1 == value -%}
                            {
                                id: "{{ variant.id }}",
                                value: "{{ variant.option2 }}",
                                image: "{{ variant.featured_image | image_url: width: 650 }}"
                            },
                            {%- endif -%}
                            {%- endfor -%}
                        ]
                    },
                    {%- else -%}
                    {
                        id: "{{ value.variant.id }}",
                        key: "{{ value | handleize }}",
                        {% render 'color-object', value: value %}
                        value: "{{ option_value }}",
                        image: "{{ value.variant.featured_image | image_url: width: 650 }}"
                    },
                    {%- endif -%}
                    {%- endfor -%}
                    {%- endif -%}

                ]
            }{%- if forloop.last != true -%},{%- endif -%}
            {%- elsif type == 'other_product' -%}

            {%- endif -%}
            {%- endfor -%}
        ];
        const getColorHTML = (product, color, index) => {
            let html = ``;
            if (product.variants.length > 1) {
                html += `<ul class="color-items flex-left">`;
                product.variants.forEach((item, i) => {
                    html += `<li class="color-item flex-center">
                                <input id="color-${product.id}-${item.key}"
                                   type="radio"
                                   name="Color-${product.id}"
                                   ${color.value === item.value ? 'checked' : ''}
                                   class="sr-only"/>
                                <label data-index="${i}"
                                       data-current="${index}"
                                       data-proxy="color"
                                       class="color-swatch tw-relative"
                                       for="color-${product.id}-${item.key}"
                                       style="--swatch-background: ${item.color}; background-image: 'url(${item.color_image})';">
                                    <span class="tooltip opacity-0 pointer-events-none text-xs rounded-full z-10">${item.value}</span>
                                </label>
                            </li>`;
                });
                html += `</ul>`;
            }
            return html;
        }

        const getVariantHTML = (variantList, variant, index) => {
            let html = ``;
            if (variantList.length > 0) {
                html += `<div class="_dropdown-root">
                            <div class="_dropdown-wrap">
                            <div class="_drop-info flex-left" data-proxy="drop">
                                <span class="drop-text tw-font-semibold">${variant.value}</span>
                                <div class="arrow-down flex-center">
                                    <svg class="svg-img"
                                         viewBox="0 0 1024 1024"
                                         xmlns="http://www.w3.org/2000/svg"
                                         width="32"
                                         height="32">
                                        <path d="M952.16851 329.603857l-61.405535-60.778248c-8.91402-8.840342-23.154349-9.061376-31.774681-0.517793L513.860882 597.050048 161.772942 254.480902c-8.729825-8.655124-23.12058-8.43409-32.108279 0.481977l-61.998029 61.367673c-9.025561 8.951883-9.248641 23.156396-0.517793 31.81152l430.986895 419.334507c8.691963 8.656147 23.083741 8.433066 32.108279-0.518816l61.997006-61.367673c1.418302-1.404999 2.589988-2.952238 3.572362-4.579295l356.838128-339.929016C961.306634 352.539218 961.084577 338.40736 952.16851 329.603857z"
                                              fill="#2c2c2c"></path>
                                    </svg>
                                </div>
                            </div>
                            <div class="_drop-items">
                                <scroll-area>
                                    <div class="scroll-view hide-scroll-bar">`;
                variantList.forEach((item, i) => {
                    html += `<div data-index="${i}" data-current="${index}" data-proxy="variant" class="drop-item ${item.value === variant.value ? 'selected' : ''} tw-font-semibold flex-left">${item.value}</div>`;
                });
                html += `</scroll-area></div></div></div>`;
            }
            return html;
        }

        const computed = index => {
            const product = productList[index];
            const color = product.variants[product.cIndex] || {};
            const variantList = color.childList || [];
            const variant = variantList.length > 0 ? variantList[product.vIndex] : color;
            return {
                product,
                color,
                variant,
                variantList
            }
        }

        const onChangeVariant = index => {
            const {variant, variantList} = computed(index);
            elemVariants[index].innerHTML = getVariantHTML(variantList, variant, index);
            elemCovers[index].innerHTML = `<img src="${variant.image}" is="lazy-image" loading="lazy" alt="" class="image"/>`;
        }

        productList.forEach(function (product, index) {
            const {color, variant, variantList} = computed(index);
            elemColors[index].innerHTML = getColorHTML(product, color, index);
            elemVariants[index].innerHTML = getVariantHTML(variantList, variant, index);
        });

        let openElemList = [];
        const onHideDrop = (ev) => {
            if (!ev.target.closest('._dropdown-root')) {
                openElemList.forEach(item => item.classList.remove('on'));
                openElemList = [];
                node.style.overflow = 'hidden';
            }
        };

        $heybike.proxy(node, ['color', 'drop', 'variant'], ({elem, type}) => {
            switch (type) {
                case 'color':
                case 'variant':
                    const current = elem.dataset.current;
                    productList[current][`${type === 'color' ? 'c' : 'v'}Index`] = Number(elem.dataset.index);
                    onChangeVariant(current);
                    break;
                case 'drop':
                    const parentNode = elem.parentNode;
                    parentNode.classList.toggle('on');
                    openElemList.push(parentNode);
                    node.style.overflow = parentNode.classList.contains('on') ? 'visible' : 'hidden';
                    break;
            }
        })

        $heybike.on('click', onHideDrop);
        $heybike.on('touchstart', onHideDrop);

        const onInitFixed = () => {
            const nav = document.querySelector('.main-navigation') || {offsetHeight: 0};
            const header = document.getElementById('main-header');
            let headerHeight = header.offsetHeight;
            let boxHeight = node.querySelector('.cover').offsetHeight || 0;
            let navHeight = nav.offsetHeight;
            $heybike.on('resize', () => {
                headerHeight = header.offsetHeight;
                boxHeight = node.querySelector('.cover').offsetHeight || 0;
                navHeight = nav.offsetHeight;
                nodeList.productWrap.style.transform = `translateX(${$heybike.isMobile ? elemScroll.scrollLeft : 0}px)`;
            });
            $heybike.bind('header:toggle', ({show}) => {
                if (show) {
                    node.style.top = `${headerHeight + navHeight - boxHeight}px`;
                } else {
                    node.style.top = `${navHeight - boxHeight}px`;
                }
            });
        }
        onInitFixed();

        $heybike.on('scroll', opt => {
            nodeList.productWrap.style.transform = `translateX(-${opt.left}px)`;
        }, elemScroll);
    })();
</script>
