            position: absolute;
            inset-inline-start: 1.828079298rem;
        }

        .mc_product-compare .compare-content .compare-box .info-items {
            padding-top: 1.624959376rem;
        }

        .mc_product-compare .compare-content .compare-box .info-items .info-item {
