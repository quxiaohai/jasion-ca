            padding: 0.2437439064rem 0.4468638284rem;
        }

        .mc_product-compare .compare-content .compare-box {
            padding: 0.4468638284rem 0;
            flex-direction: column;
        }

        .mc_product-compare .compare-content .compare-box .title {
