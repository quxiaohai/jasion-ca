        }

        .mc_product-compare .compare-content .product-items .product-item .variant-selects .color-items {
            gap: 0.3656158596rem;
            padding-bottom: 0.2437439064rem;
        }

        .mc_product-compare .compare-content .product-items .product-item .variant-selects ._dropdown-root {
            min-height: 1.2593435164rem;
            width: 100%;
            margin-top: 0.2rem;
        }

        .mc_product-compare .compare-content .product-items .product-item .variant-selects ._dropdown-wrap {
            min-height: 1.2593435164rem;
        }

        .mc_product-compare .compare-content .product-items .product-item .variant-selects ._dropdown-wrap ._drop-items {
            border-radius: 0.4rem;
        }

        .mc_product-compare .compare-content .product-items .product-item .variant-selects ._dropdown-wrap ._drop-info {
            height: 1.218719532rem;
            max-width: 10.1559961001rem;
        }

        .mc_product-compare .compare-content .product-items .product-item .variant-selects ._dropdown-wrap ._drop-info .drop-text {
            font-size: 0.6296717582rem;
            padding-right: 0.4874878128rem;
        }

        .mc_product-compare .compare-content .product-items .product-item .variant-selects ._dropdown-wrap ._drop-info .arrow-down {
            width: 0.6499837504rem;
            height: 0.6499837504rem;
        }

        .mc_product-compare .compare-content .product-items .product-item .variant-selects ._dropdown-wrap .scroll-view {
            max-height: 6.4998375041rem;
        }

        .mc_product-compare .compare-content .product-items .product-item .variant-selects ._dropdown-wrap ._drop-items {
