          "label": "Item text #2"
        },
        {
          "type": "image_picker",
          "id": "item_icon3",
          "label": "Item icon #3"
        },
        {
          "type": "text",
          "id": "item_text3",
          "label": "Item text #3"
        },
        {
          "type": "image_picker",
          "id": "item_icon4",
          "label": "Item icon #4"
        },
        {
          "type": "text",
          "id": "item_text4",
          "label": "Item text #4"
        },
        {
          "type": "image_picker",
          "id": "item_icon5",
          "label": "Item icon #5"
        },
        {
          "type": "text",
          "id": "item_text5",
          "label": "Item text #5"
        },
        {
          "type": "image_picker",
