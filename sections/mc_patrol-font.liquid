<style>
    @font-face {
        font-family: "{{ section.settings.font_name }}";
        src: url(data:application/x-font-ttf;charset=utf-8;base64,) format("truetype"); /* chrome、firefox、opera、Safari, Android, iOS 4.2+ */
        font-style: normal;
        font-weight: normal;
        font-display: swap;
    }

    .font-{{ section.settings.font_name }} {
        font-family: '{{ section.settings.font_name }}', Inter, sans-serif;
    }

    body #PageContainer{
        background: #000000 !important;
    }
</style>
{% schema %}
{
    "name": "MC Patrol Font",
    "presets": [
        {
            "name": "MC Patrol Font"
        }
    ],
    "settings": [
        {
            "type": "text",
            "id": "font_name",
            "label": "Font name",
            "default": "rushblade"
        }
    ]
}
{% endschema %}