{%- assign ss = section.settings -%}
{%- assign winner_list = section.blocks | where: 'type', 'winner' -%}
<style>
    .autumn-sale-win-prize {
        padding: 40px 0;
        background-color: #f9f7f6;
    }
    .autumn-sale-win-prize .autumn-content {
        max-width: 1376px;
        box-sizing: border-box;
        padding: 0 48px;
        margin: 0 auto;
    }
    .autumn-sale-win-prize .prize-content {
        width: 100%;
        background-color: #fedb96;
        border-radius: 20px;
    }
    .autumn-sale-win-prize .prize-content .prize-banner {
        padding: 0 69px;
        text-align: center;
    }
    .autumn-sale-win-prize .prize-content .title {
        font-size: 68px;
        font-weight: 900;
        color: #000000;
        line-height: 1.2;
        padding: 24px 0 10px;
    }
    .autumn-sale-win-prize .prize-content .description,
    .autumn-sale-win-prize .prize-content .remark {
        font-size: 16px;
        font-weight: 600;
        line-height: 1.625;
        color: #000000;
    }
    .autumn-sale-win-prize .prize-content .description strong,
    .autumn-sale-win-prize .prize-content .description b,
    .autumn-sale-win-prize .prize-content .remark strong,
    .autumn-sale-win-prize .prize-content .remark b {
        font-size: 20px;
        font-weight: 900;
        color: #d50101;
        line-height: 1.2;
    }
    .autumn-sale-win-prize .prize-content .remark {
        max-width: 910px;
        margin: 22px auto 20px;
    }
    .autumn-sale-win-prize .prize-content .prize-box {
        margin-top: 28px;
        gap: 0 15px;
    }
    .autumn-sale-win-prize .prize-content .prize-box .item {
        width: 50%;
        height: 156px;
        background-color: #ffffff;
        border-radius: 16px;
        position: relative;
    }
    .autumn-sale-win-prize .prize-content .prize-box .item .name {
        font-weight: 700;
        font-size: 20px;
        line-height: 1.6;
        color: #000000;
    }
    .autumn-sale-win-prize .prize-content .prize-box .item .desc {
