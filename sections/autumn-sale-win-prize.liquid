<div class="autumn-sale-win-prize section--page">
    <div class="autumn-content">
        <div class="prize-content">
            <div class="prize-banner">
                <div class="title">{{ ss.title }}</div>
                <div class="description">
                    {{ ss.description }}
                </div>
                <div class="prize-box flex-between">
                    {%- assign first_prize = section.blocks | where: 'type', 'first_prize' | first -%}
                    {%- if first_prize != blank -%}
                        {%- assign bs = first_prize.settings -%}
                        <div class="item item-1 flex-between">
                            <div class="info">
                                <div class="name">{{ bs.title }}</div>
                                <div class="desc">
                                    {{ bs.desc }}
                                </div>
                            </div>
                            <div class="prize-img">
                                {%- render 'global-image', desktop_img: bs.prize_image, desktop_size: 200 -%}
                            </div>
                            <div class="prize-tag">
                                <img alt=""
                                     src="https://cdn.shopify.com/s/files/1/0605/0044/3373/files/autumn-prize-1.png?v=1763692365"
                                     loading="lazy" class="image"/>
                            </div>
                        </div>
                    {%- endif -%}
                    {%- assign second_prize = section.blocks | where: 'type', 'second_prize' | first -%}
                    {%- if second_prize != blank -%}
                        {%- assign bs = second_prize.settings -%}
                        <div class="item item-2 flex-center-col">
                            <div class="name">{{ bs.title }}</div>
                            <div class="desc">
                                {{ bs.desc }}
                            </div>
                            <div class="prize-list flex-center">
                                {%- for v in (1..4) -%}
                                    {%- assign prize_image = 'prize_image' | append: v -%}
                                    {%- if bs[prize_image] != blank -%}
                                        <div class="item flex-center">
                                            {%- render 'global-image', desktop_img: bs[prize_image], media_type: 'icon' -%}
                                        </div>
                                    {%- endif -%}
                                {%- endfor -%}
                            </div>
                            <div class="prize-tag">
                                <img alt=""
                                     src="https://cdn.shopify.com/s/files/1/0605/0044/3373/files/autumn-prize-2.png?v=1763692365"
                                     loading="lazy" class="image"/>
                            </div>
                        </div>
                    {%- endif -%}
                </div>
                <div class="remark">
                    {{ ss.remark }}
                </div>
                <div class="button-group flex-center">
                    <a href="{{ bs.button_url }}" class="button flex-center">{{ bs.button_text }}</a>
                </div>
            </div>
            <div class="winning-box flex-left">
                <img alt="" src="https://cdn.shopify.com/s/files/1/0605/0044/3373/files/autumn-prize-cloud.png?v=1763692365&width=800" loading="lazy" class="image desktop-done" />
                <img alt="" src="https://cdn.shopify.com/s/files/1/0605/0044/3373/files/autumn-mb-prize-cloud.png?v=1763692365&width=700" loading="lazy" class="image mobile-done" />
                <div class="gift-img">
                    {%- render 'global-image',
                            desktop_img: ss.desktop_gift_image,
                            desktop_size: 600,
                            mobile_img: ss.mobile_gift_image,
                            mobile_size: 500
                    -%}
                </div>
                <div class="prize-winner-list">
                    <img alt="" src="https://cdn.shopify.com/s/files/1/0605/0044/3373/files/autumn-prize-win-back.png?v=1763692365&width=800" loading="lazy" class="image desktop-done" />
                    <img alt="" src="https://cdn.shopify.com/s/files/1/0605/0044/3373/files/autumn-mb-prize-win-back.png?v=1763692365&width=700" loading="lazy" class="image mobile-done" />
                    <div class="name">{{ ss.prize_list_name }}</div>
                    <div class="winner-marquee">
                        <ul class="winner-list">
                            {%- for block in winner_list -%}
                                {%- assign bs = block.settings -%}
                                <li class="winner-item flex-between">
                                    <div class="prize">{{ bs.prize }}</div>
                                    <div class="winner">{{ bs.title }}</div>
                                </li>
                            {%- endfor -%}
                            {%- for block in winner_list -%}
                                {%- assign bs = block.settings -%}
                                <li class="winner-item flex-between">
                                    <div class="prize">{{ bs.prize }}</div>
                                    <div class="winner">{{ bs.title }}</div>
                                </li>
                            {%- endfor -%}
                        </ul>
                    </div>
                </div>
