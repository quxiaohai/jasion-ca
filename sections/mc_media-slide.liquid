{%- liquid
    assign ss = section.settings
-%}
<style>
    .mc_media-slide {
        background: #ffffff;
        padding: 60px 0;
    }

    .mc_media-slide .slide-content .slide-tabs {
        background-color: {{ ss.slide_tab_bg_color }};
        padding: 5px;
        gap: 0 15px;
        border-radius: 100px;
    }

    .mc_media-slide .slide-content .slide-tabs .tab {
        height: 40px;
        padding: 0 35px;
        border-radius: 100px;
        cursor: pointer;
        line-height: 1.2;
        font-size: 19px;
        font-weight: 900;
        color: {{ ss.slide_tab_color }};
        transition: background-color 0.5s;
    }

    .mc_media-slide .slide-content .slide-tabs .tab.active {
        background-color: {{ ss.slide_tab_active_color }};
    }

    .mc_media-slide .slide-content .media-slide-items {
        width: 1073px;
        margin-top: 32px;
    }

    .mc_media-slide .slide-content .media-slide-items .slide-item {
        width: 100%;
        display: none;
    }

    .mc_media-slide .slide-content .media-slide-items .slide-item .media-wrap {
        aspect-ratio: {{ ss.image_ratio }};
        position: relative;
        border-radius: 20px;
        overflow: hidden;
    }

    .mc_media-slide .slide-content .media-slide-items .slide-item .media-wrap:before {
        content: "";
        width: 100%;
        height: 5px;
        background-color: {{ ss.slide_tab_active_color }};
        left: 0;
        bottom: 0;
        position: absolute;
        opacity: 1;
        transform: translateX(var(--translate-x));
        transition: transform {{ ss.duration | times: 100 }}ms linear;
    }

    .mc_media-slide .slide-content .media-slide-items .slide-item.active {
        display: block;
    }

    .mc_media-slide .slide-content .media-slide-items .slide-item .text {
        font-size: 16px;
        line-height: 1.7;
        color: {{ ss.slide_text_color }};
        padding-top: 22px;
        text-align: center;
    }

    .mc_media-slide .slide-content .media-slide-items .slide-item .image,
    .mc_media-slide .slide-content .media-slide-items .slide-item .video {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    @media screen and (max-width: 1023px) {
        .mc_media-slide {
            padding: 1.875rem 0;
        }

        .mc_media-slide .slide-content .slide-tabs {
            padding: 0.15625rem;
            gap: 0 0.375rem;
            overflow-x: auto;
            width: 100%;
        }

        .mc_media-slide .slide-content .slide-tabs .tab {
            height: 1.6875rem;
            padding: 0 0.875rem;
            font-size: 0.75rem;
            white-space: nowrap;
        }

        .mc_media-slide .slide-content .media-slide-items {
            width: 100%;
            margin-top: 0.8rem;
        }

        .mc_media-slide .slide-content .media-slide-items .slide-item {
            width: 100%;
        }

        .mc_media-slide .slide-content .media-slide-items .slide-item .media-wrap {
            border-radius: 0.625rem;
            aspect-ratio: {{ ss.mb_image_ratio }};
        }

        .mc_media-slide .slide-content .media-slide-items .slide-item .media-wrap:before {
            height: 3px;
        }

        .mc_media-slide .slide-content .media-slide-items .slide-item .text {
            font-size: 0.75rem;
            line-height: 1.5;
            padding-top: 0.5625rem;
        }
    }

    {% render 'page-wrap-style' %}
</style>
<div class="mc_media-slide section--page" id="{{ section.id }}-slide">
    {%- render 'section-title', info: ss -%}
    <div class="slide-content page-width flex-center-col">
        <animate-element class="slide-tabs hide-scroll-bar flex-left" node-name="scroll" data-animate="fade-in">
            {%- for block in section.blocks -%}
                {%- assign bs = block.settings -%}
                <div node-name="tab"
                     data-proxy="tab"
                     data-index="{{ forloop.index0 }}"
                     class="tab flex-center{% if forloop.first %} active{% endif %}">
                    {{ bs.title }}
                </div>
            {%- endfor -%}
        </animate-element>
        <div class="media-slide-items">
            {%- for block in section.blocks -%}
                {%- assign bs = block.settings -%}
                <animate-element node-name="panel"
                                 data-animate="fade-in"
                                 data-repeat
                                 class="slide-item{% if forloop.first %} active{% endif %}">
                    <div class="media-wrap" node-name="media" style="--translate-x: -100%;">
                        {%- render 'global-image',
                            desktop_img: bs.pc_image,
                            desktop_size: 1200,
                            mobile_img: bs.mb_image,
                            mobile_size: 700
                        -%}
                    </div>
                    <div class="text">{{ bs.intro }}</div>
                </animate-element>
            {%- endfor -%}
        </div>
    </div>
</div>
{%- if section.blocks.size > 1 -%}
    <script>
        (function () {
            const node = document.getElementById('{{ section.id }}-slide');
            let current = 0;

            const {nodeList, trigger} = $heybike.tabSwitch({
                root: node,
                device: 'mobile',
                cb: ({index, self}) => {
                    if (self) {
                        return false;
                    }
                    {%- if ss.auto_slide -%}
                    updateProgress(0);
                    current = index;
                    startSlide();
                    {%- endif -%}
                }
            });

            {%- if ss.auto_slide -%}
            const updateProgress = (percentage) => {
                nodeList.media[current].style.setProperty("--translate-x", `-${100 - percentage}%`);
            };
            let timer = null;
            const startSlide = () => {
                let i = 0;
                clearInterval(timer);
                updateProgress(i);
                timer = setInterval(() => {
                    if (i >= 100) {
                        clearInterval(timer);
                        let next = current + 1;
                        if (next >= {{ section.blocks.size }}) {
                            next = 0;
                        }
                        trigger(nodeList.tab[next]);
                        return false;
                    }
                    i += 10;
                    updateProgress(i);
                }, {{ ss.duration | times: 100 }});
            };
            $heybike.inView(node, () => {
                startSlide();
                return () => {
                    clearInterval(timer);
                }
            });
            {%- endif -%}
        })();
    </script>
{%- endif -%}
{% schema %}
{
  "name": "MC Media Slide",
  "class": "mc--main",
  "tag": "section",
  "presets": [
    {
      "name": "MC Media Slide"
    }
  ],
  "settings": [
    {
      "type": "color",
      "id": "page_color",
      "label": "Background Color"
    },
    {
      "type": "number",
      "id": "page_top",
      "label": "Padding Top"
    },
    {
      "type": "number",
      "id": "page_bottom",
      "label": "padding Bottom"
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show Title",
      "default": false
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Title"
    },
    {
      "type": "select",
      "id": "title_style",
      "label": "Title font style",
      "options": [
        {
          "label": "Normal",
          "value": "normal"
        },
        {
          "label": "italic",
          "value": "italic"
        }
      ],
      "default": "normal"
    },
    {
      "type": "range",
      "id": "title_pc_size",
      "label": "Desktop title size",
      "min": 12,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "title_mb_size",
      "label": "Mobile title size",
      "min": 6,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "number",
      "id": "title_margin_bottom",
      "label": "Title margin bottom",
      "default": 16
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "title_bold_color",
      "label": "Title Bold color",
      "default": "#ffffff"
    },
    {
      "type": "color_background",
      "id": "title_gradient_color",
      "label": "Title gradient color"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show description",
      "default": false
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "description_pc_size",
      "label": "Desktop description size",
      "min": 12,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "description_mb_size",
      "label": "Mobile description size",
      "min": 6,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "number",
      "id": "description_pc_margin_bottom",
      "label": "Desktop description margin bottom",
      "default": 40
    },
    {
      "type": "number",
      "id": "description_mb_margin_bottom",
      "label": "Mobile description margin bottom",
      "default": 30
    },
    {
      "type": "header",
      "content": "Slide color"
    },
    {
      "type": "color",
      "id": "slide_tab_bg_color",
      "label": "Slide tab background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "slide_tab_color",
      "label": "Slide tab color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "slide_tab_active_color",
      "label": "Slide tab active color",
      "default": "#ff981d"
    },
    {
      "type": "color",
      "id": "slide_text_color",
      "label": "Slide text color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Slide"
    },
    {
      "type": "text",
      "id": "image_ratio",
      "label": "Desktop image ratio(w/h)",
      "default": "2/1"
    },
    {
      "type": "text",
      "id": "mb_image_ratio",
      "label": "Mobile image ratio(w/h)",
      "default": "2/1"
    },
    {
      "type": "checkbox",
      "id": "auto_slide",
      "label": "Auto slide",
      "default": true
    },
    {
      "type": "range",
      "id": "duration",
      "label": "Slide speed duration",
      "min": 1,
      "max": 20,
      "step": 1,
      "unit": "s",
      "default": 4
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide card",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "intro",
          "label": "Intro"
        },
        {
          "type": "image_picker",
          "id": "pc_image",
          "label": "Desktop image"
        },
        {
          "type": "image_picker",
          "id": "mb_image",
          "label": "Mobile image"
        }
      ]
    }
  ]
}
{% endschema %}
