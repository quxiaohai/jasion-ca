{%- assign ss = section.settings -%}
<style>
  .mc_patrol-card-slide {
    padding: 80px 0;
    background-color: #000000;
  }
  .mc_patrol-card-slide .card-content > .card-item ~ .card-item {
    display: none;
  }
  .mc_patrol-card-slide .card-content .card-item {
    height: auto;
    min-height: 100%;
    width: calc((100vw - 108px - var(--page-padding) * 2) / 3);
    margin-right: 36px;
    overflow: hidden;
    background-color: #000000;
    display: flex;
    flex-direction: column;
    padding-bottom: 1px;
  }
  .mc_patrol-card-slide .card-content .card-item:before {
    content: "";
    background: url("data:image/png;base64,") no-repeat;
    background-size: 100% 100%;
    aspect-ratio: 6.8;
    width: 100%;
    position: absolute;
    left: 0;
    bottom: 0;
  }
  .mc_patrol-card-slide .card-content .card-item .cover {
    aspect-ratio: 1.0845;
    padding: 1px;
    height: auto;
    transform: translateY(2px);
  }
  .mc_patrol-card-slide .card-content .card-item .border-image {
    top: 0;
    left: 0;
    object-fit: fill;
  }
  .mc_patrol-card-slide .card-content .media-info {
    width: 100%;
    flex: 1;
    box-sizing: border-box;
    padding: 26px 40px 70px 26px;
    background: url("data:image/png;base64,") repeat-y;
    background-size: 100% 1px;
  }
  .mc_patrol-card-slide .card-content .media-info .intro,
  .mc_patrol-card-slide .card-content .media-info .name {
    width: 100%;
    text-align: left;
    color: #ffffff;
  }
  .mc_patrol-card-slide .card-content .media-info .intro {
    line-height: 1.3333;
    padding-top: 10px;
    font-size: 18px;
  }
  .mc_patrol-card-slide .card-content .media-info .name {
    line-height: 1.2;
    font-weight: 700;
    font-size: 30px;
  }
  .custom-slide-button .flickity-enabled {
    padding-bottom: 68px;
    position: relative;
  }
  .custom-slide-button .flickity-button {
    transform: translateY(0);
    inset-block-start: 0;
    bottom: 0;
    width: 48px;
    height: 48px;
    background-color: #ffe500;
    top: auto;
    inset-inline-start: auto;
    right: 0;
    display: flex;
  }
  .custom-slide-button .flickity-button:before {
    content: "";
    width: 17px;
    height: 33px;
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
    background: url("data:image/png;base64,") no-repeat;
    background-size: 100% 100%;
  }
  .custom-slide-button .flickity-button.next:before {
    transform: translate(-36%, -50%);
  }
  .custom-slide-button .flickity-button.previous {
    transform: translateX(-58px);
  }
  .custom-slide-button .flickity-button.previous:before {
    transform: rotate(180deg) translate(66%, 50%);
  }
  .custom-slide-button .flickity-button svg {
    display: none;
  }
  .custom-slide-button .flickity-button:focus {
    box-shadow: none;
  }
  .custom-slide-button .flickity-button:disabled {
    background-color: #4d4d4b;
    opacity: 1;
  }
  @media screen and (max-width: 2200px) {
    .mc_patrol-card-slide .custom-slide-button {
      padding-right: 0;
    }
    .mc_patrol-card-slide .card-content .card-item {
      width: calc((95.4vw - var(--page-padding) * 2) / 3);
      margin-right: 1.8vw;
    }
    .mc_patrol-card-slide .card-content .card-item .cover {
      transform: translateY(1px);
    }
    .mc_patrol-card-slide .custom-slide-button .flickity-button {
      right: var(--page-padding);
    }
  }
  @media screen and (max-width: 1440px) {
    .mc_multicolumn-card-slide {
      padding: 68px 0;
    }
    .mc_multicolumn-card-slide .card-content.column-card-1 .card-item {
      margin-right: 62px;
    }
    .mc_multicolumn-card-slide .card-content.column-card-1 .card-item .media-info {
      padding: 31px 43px 44px;
    }
    .mc_multicolumn-card-slide .card-content.column-card-1 .card-item .media-info .intro {
      padding-top: 15px;
    }
    .mc_multicolumn-card-slide .card-content.column-card-3 .card-item .media-info {
      padding: 0 34px 32px;
    }
    .mc_multicolumn-card-slide .card-content .card-item {
      border-radius: 0px 0px 26px 0px;
    }
    .mc_multicolumn-card-slide .card-content .media-info {
      padding: 22px 17px 29px;
    }
    .mc_multicolumn-card-slide .card-content .media-info .intro {
      padding-top: 9px;
      font-size: 15px;
    }
    .mc_multicolumn-card-slide .card-content .media-info .name {
      font-size: 26px;
    }
  }
  @media screen and (max-width: 1023px) {
    .mc_patrol-card-slide {
      padding: 2.5rem 0;
    }
    .mc_patrol-card-slide .title,
    .mc_patrol-card-slide .description {
      text-align: left;
    }
    .mc_patrol-card-slide .card-content .card-item {
      width: 9.375rem;
      margin-right: 0.28125rem;
    }
    .mc_patrol-card-slide .card-content .media-info {
      box-sizing: border-box;
      padding: 0.40625rem 1.25rem 1.5rem 0.625rem;
      background-color: #4d4d4b;
    }
    .mc_patrol-card-slide .card-content .media-info .intro {
      padding-top: 0.3125rem;
      font-size: 0.5rem;
    }
    .mc_patrol-card-slide .card-content .media-info .name {
      font-size: 0.75rem;
      height: 1.8125rem;
    }
    .custom-slide-button .flickity-button {
      display: none;
    }
    .custom-slide-button .flickity-enabled {
      padding-bottom: 0;
    }
  }
    {% render 'page-wrap-style' %}
</style>
<div class="mc_patrol-card-slide section--page w-full">
    {% render 'section-title', info: ss, font: 'rushblade' %}
  <div class="page-width custom-slide-button">
    <slide-element
        buttons
        class="card-content block">
      {%- for block in section.blocks -%}
        {%- assign bs = block.settings -%}
        <div class="card-item flex-column relative">
          <div class="cover overflow-hidden w-full relative">
            {% render 'global-image', desktop_img: bs.desktop_image, desktop_size: 500, mobile_img: bs.mobile_image, mobile_size: 500 %}
            <img src="https://cdn.shopify.com/s/files/1/0605/0044/3373/files/image-border-3.png?v=1772003965" class="absolute border-image image" alt="Card border image" />
          </div>
          <div class="media-info">
            <div class="name">{{ bs.title }}</div>
            <div class="intro">
              {{ bs.intro }}
            </div>
          </div>
        </div>
      {%- endfor -%}
    </slide-element>
  </div>
</div>
{% schema %}
{
  "name": "Mc Patrol card Slide",
  "class": "mc--main",
  "tag": "section",
  "presets": [
    {
      "name": "Mc Patrol card Slide"
    }
  ],
  "settings": [
    {
      "type": "color",
      "id": "page_color",
      "label": "Background Color"
    },
    {
      "type": "number",
      "id": "page_top",
      "label": "Padding Top"
    },
    {
      "type": "number",
      "id": "page_bottom",
      "label": "padding Bottom"
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show Title",
      "default": true
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Title",
      "default": "<p>Title</p>"
    },
    {
      "type": "range",
      "id": "title_pc_size",
      "label": "Desktop title size",
      "min": 12,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "title_pc_weight",
      "label": "Desktop title weight",
      "min": 200,
      "max": 900,
      "step": 100,
      "unit": "w",
      "default": 700
    },
    {
      "type": "range",
      "id": "title_pc_line",
      "label": "Desktop title line height",
      "min": 100,
      "max": 300,
      "step": 10,
      "unit": "%",
      "default": 120
    },
    {
      "type": "range",
      "id": "title_mb_size",
      "label": "Mobile title size",
      "min": 6,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "title_mb_weight",
      "label": "Mobile title weight",
      "min": 200,
      "max": 900,
      "step": 100,
      "unit": "w",
      "default": 700
    },
    {
      "type": "range",
      "id": "title_mb_line",
      "label": "Mobile title line height",
      "min": 100,
      "max": 300,
      "step": 10,
      "unit": "%",
      "default": 120
    },
    {
      "type": "number",
      "id": "title_margin_bottom",
      "label": "Title margin bottom",
      "default": 16
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "title_bold_color",
      "label": "Title bold color",
      "default": "#ffffff"
    },
    {
      "type": "color_background",
      "id": "title_gradient_color",
      "label": "Title gradient color"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show description",
      "default": false
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>description</p>"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "description_bold_color",
      "label": "Description bold color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "description_pc_size",
      "label": "Desktop description size",
      "min": 12,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "description_pc_line",
      "label": "Desktop description line height",
      "min": 100,
      "max": 300,
      "step": 10,
      "unit": "%",
      "default": 120
    },
    {
      "type": "range",
      "id": "description_mb_size",
      "label": "Mobile description size",
      "min": 6,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "description_mb_line",
      "label": "Mobile description line height",
      "min": 100,
      "max": 300,
      "step": 10,
      "unit": "%",
      "default": 120
    },
    {
      "type": "number",
      "id": "description_pc_margin_bottom",
      "label": "Desktop description margin bottom",
      "default": 40
    },
    {
      "type": "number",
      "id": "description_mb_margin_bottom",
      "label": "Mobile description margin bottom",
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "media",
      "name": "Media Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "desktop_image",
          "label": "Desktop Backdrop Image"
        },
        {
          "type": "image_picker",
          "id": "mobile_image",
          "label": "Mobile Backdrop Image"
        },
        {
          "type": "textarea",
          "id": "title",
          "label": "Title",
          "default": "Magnetic Emergency Switch"
        },
        {
          "type": "richtext",
          "id": "intro",
          "label": "Intro"
        }
      ]
    }
  ]
}
{% endschema %}
