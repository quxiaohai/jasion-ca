{%- assign ss = section.settings -%}
{% stylesheet %}
    .mc_fifa-spin {
        padding: 36px 0;
    }

    .mc_fifa-spin .spin-content {
        gap: 0 80px;
        align-items: flex-start;
    }

    .mc_fifa-spin .spin-content .title {
        font-size: 32px;
        color: #ffffff;
    }

    .mc_fifa-spin .spin-content .items {
        gap: 18px;
        padding-top: 26px;
    }

    .mc_fifa-spin .spin-content .item {
        gap: 16px;
    }

    .mc_fifa-spin .spin-content .item .image {
        max-width: 32px;
        max-height: 32px;
        object-fit: contain;
    }

    .mc_fifa-spin .spin-content .item .text {
        font-size: 20px;
        color: #fdb404;
    }

    .mc_fifa-spin .spin-wrap {
        width: 500px;
        height: 527px;
    }

    .mc_fifa-spin .spin-wrap .image {
        object-fit: fill;
    }

    .mc_fifa-spin .spin-wrap .spin-image {
        left: 28px;
        top: 47px;
        width: 445px;
        height: auto;
        aspect-ratio: 1;
        transition: transform 80ms linear;
    }

    .mc_fifa-spin .form-wrap .form-success {
        color: #FFFFFF;
        font-size: 24px;
        padding: 32px 0 8px;
        gap: 12px;
    }

    .mc_fifa-spin .form-wrap .form-success .icon {
        width: 28px;
        height: 28px;
    }

    .mc_fifa-spin .form-wrap {
        width: 393px;
        padding-top: 20px;
    }

    .mc_fifa-spin .form-wrap .remark {
        padding-top: 40px;
        font-size: 20px;
        color: #ffffff;
    }

    .mc_fifa-spin .form-wrap .field {
        margin-top: 16px;
        gap: 16px;
    }

    .mc_fifa-spin .form-wrap .field .input-wrap {
        height: 52px;
        background-color: #ffffff;
        border-radius: 10px;
    }

    .mc_fifa-spin .form-wrap .field input {
        background: none;
        line-height: 46px;
        font-size: 16px;
        color: #000000;
        border: 0 none;
        padding: 0 23px;
    }

    .mc_fifa-spin .form-wrap .field .button {
        height: 52px;
        max-height: none;
        font-size: 24px;
        color: #324909;
        border-radius: 10px;
        background: #fdb404;
        transform: none !important;
        transition: background-color 0.3s;
        transition-property: background-color, color;
    }

    .mc_fifa-spin .form-wrap .field .button:hover {
        background-color: #000000;
        color: #ffffff;
    }

    .mc_fifa-spin .privacy-info {
        padding-top: 14px;
        line-height: 1.2;
        cursor: pointer;
    }

    .mc_fifa-spin .privacy-info.checked .checkbox {
        background-color: #fdb404;
        border-color: #fdb404;
    }

    .mc_fifa-spin .privacy-info.checked .checkbox .svg-icon {
        opacity: 1;
    }

    .mc_fifa-spin .privacy-info .checkbox {
        width: 16px;
        min-width: 16px;
        height: 16px;
        position: static;
        box-sizing: border-box;
        border: 1.5px solid #ffffff;
        transition: all 0.5s;
    }

    .mc_fifa-spin .privacy-info .checkbox .svg-icon {
        width: 10px;
        opacity: 0;
    }

    .mc_fifa-spin .privacy-info .text {
        line-height: 1.3;
        padding-left: 7px;
        font-size: 14px;
        color: #ffffff;
        word-break: break-all;
        text-align: left;
    }

    .mc_fifa-spin .privacy-info .text a {
        color: #ffffff;
        font-weight: 500;
    }

    .mc_fifa-spin .privacy-info .text a:hover {
        text-decoration: underline;
    }

    @media screen and (max-width: 1023px) {
        .mc_fifa-spin {
            padding: 1.171875rem 0 0.68359375rem;
        }

        .mc_fifa-spin .spin-content {
            gap: 0;
            flex-direction: column;
            align-items: center;
        }

        .mc_fifa-spin .spin-content .title {
            font-size: 0.703125rem;
        }

        .mc_fifa-spin .spin-content .items {
            gap: 1.953125rem;
            padding-top: 0.8203125rem;
        }

        .mc_fifa-spin .spin-content .item {
            gap: 0.390625rem;
        }

        .mc_fifa-spin .spin-content .item .image {
            max-width: 1.25rem;
            max-height: 1.25rem;
        }

        .mc_fifa-spin .spin-content .item .text {
            font-size: 0.703125rem;
        }

        .mc_fifa-spin .spin-wrap {
            margin-top: 1.0546875rem;
            width: 14.609375rem;
            height: 14.765625rem;
        }

        .mc_fifa-spin .spin-wrap .spin-image {
            left: 0.7421875rem;
            top: 0.87890625rem;
            width: 13.0859375rem;
        }

        .mc_fifa-spin .form-wrap {
            width: 13.92578125rem;
            padding-top: 0.9375rem;
            text-align: center;
        }

        .mc_fifa-spin .form-wrap .remark {
            padding-top: 0.78125rem;
            font-size: 0.703125rem;
        }

        .mc_fifa-spin .form-wrap .field {
            margin-top: 0.5078125rem;
            gap: 0.60546875rem;
        }

        .mc_fifa-spin .form-wrap .field .input-wrap {
            height: 1.81640625rem;
            border-radius: 0.1953125rem;
        }

        .mc_fifa-spin .form-wrap .field input {
            line-height: 1.5625rem;
            font-size: 0.703125rem;
            padding: 0 0.8203125rem;
        }

        .mc_fifa-spin .form-wrap .field .button {
            height: 1.81640625rem;
            font-size: 0.91796875rem;
            border-radius: 0.1953125rem;
        }

        .mc_fifa-spin .privacy-info {
            padding-top: 0.64453125rem;
        }

        .mc_fifa-spin .privacy-info .checkbox {
            width: 14px;
            min-width: 14px;
            height: 14px;
        }

        .mc_fifa-spin .privacy-info .checkbox .svg-icon {
            width: 9px;
        }

        .mc_fifa-spin .privacy-info .text {
            padding-left: 0.3515625rem;
            font-size: 10px;
        }
    }
{% endstylesheet %}
{% render 'page-wrap-style', load_style: true %}
<div class="mc_fifa-spin section--page" id="{{ section.id }}-spin">
    {%- render 'section-title', info: ss -%}
    {%- if ss.seo_text != blank -%}
        <{{ ss.seo_tag }} class="seo-tag-hidden">{{ ss.seo_text }}</{{ ss.seo_tag }}>
    {%- endif -%}
    {%- capture item_mb_code -%}
        {%- for v in (1..4) -%}
            {%- assign text = 'item_text' | append: v -%}
            {%- assign icon = 'item_icon' | append: v -%}
            {%- if ss[text] != blank -%}
                <li class="item flex-center-col">
                    {%- if ss[icon] != blank -%}
                        {%- render 'global-image', image: ss[icon], image_size: 100 -%}
                    {%- endif -%}
                    <span class="text fw-700 lh-2">{{ ss[text] }}</span>
                </li>
            {%- endif -%}
        {%- endfor -%}
    {%- endcapture -%}
    {%- capture item_code -%}
        {%- for v in (1..4) -%}
            {%- assign text = 'item_text' | append: v -%}
            {%- assign icon = 'item_icon' | append: v -%}
            {%- if ss[text] != blank -%}
                <li class="item flex-left">
                    {%- if ss[icon] != blank -%}
                        {%- render 'global-image', image: ss[icon], image_size: 100 -%}
                    {%- endif -%}
                    <span class="text fw-700 lh-2">{{ ss[text] }}</span>
                </li>
            {%- endif -%}
        {%- endfor -%}
    {%- endcapture -%}
    <div class="spin-content flex-center">
        <div class="title mobile-done text-center fw-600 lh-2">
            {{ ss.title }}
        </div>
        {%- if item_mb_code != blank -%}
            <ul class="items mobile-done:flex flex-center">
                {{ item_mb_code }}
            </ul>
        {%- endif -%}
        <div class="spin-wrap relative">
            {%- render 'global-image', image: ss.spin_background_image, image_size: 800, class: 'backdrop-image relative z-2' -%}
            {%- render 'global-image', image: ss.spin_turntable_image, image_size: 600, class: 'spin-image absolute z-1' -%}
        </div>
        {%- assign form_id = 'form-' | append: section.id -%}
        {%- form 'customer', id: form_id, class: 'form-wrap flex-column relative' -%}
            <div class="title desktop-done fw-600 lh-2">{{ ss.title }}</div>
            {%- if item_code != blank -%}
                <ul class="items desktop-done flex-column">
                    {{ item_code }}
                </ul>
            {%- endif -%}
            {%- if ss.form_remark != blank -%}
                <div class="remark lh-4 fw-700">{{ ss.form_remark }}</div>
            {%- endif -%}
            <div class="form-info" node-name="formInfo">
                <div class="field flex-column">
                    <label class="input-wrap flex-left w-full">
                        <input class="default-input w-full"
                               node-name="email"
                               type="email"
                               name="contact[email]"
                               value="" autocorrect="off"
                               autocapitalize="off"
                               autocomplete="email"
                               placeholder="{{ ss.placeholder }}"
                               required=""/>
                    </label>
                    <button type="submit"
                            node-name="submit"
                            class="button button--primary flex-center"
                            is="hover-button"
                            aria-label="{{ ss.button }}">
                        <span class="btn-text">{{ ss.button }}</span>
                    </button>
                </div>
                {%- if ss.show_privacy -%}
                    <div node-name="privacy"
                         class="privacy-info{% if ss.privacy_checked %} checked{% endif %} flex-top">
                        <div class="checkbox flex-center">
                            <svg class="svg-icon" xmlns="http://www.w3.org/2000/svg" width="10.707" height="7.511"
                                 viewBox="0 0 10.707 7.511">
                                <path d="M-11467.566,874.83l3.55,3.55,6.45-6.451"
                                      transform="translate(11467.92 -871.575)" fill="none" stroke="#fff"
                                      stroke-width="1"></path>
                            </svg>
                        </div>
                        <div class="text flex-bottom">
                            {{ ss.privacy_text }}
                        </div>
                    </div>
                {%- endif -%}
            </div>
        {%- endform -%}
    </div>
    {%- liquid
        assign discount = section.blocks | first
        assign ds = discount.settings
        render 'spin-popup', ds: ds
    -%}
</div>
{%- if discount != blank -%}
    <script>
        $heybike.ready(() => {
            const node = document.getElementById('{{ section.id }}-spin');
            const nodeList = $heybike.getNodeList(node);
            const form = document.getElementById('{{ form_id }}');
            const spinElem = node.querySelector('.spin-image');
            let currentRotation = 0.0;
            let animating = false;
            let animStartTime = 0;
            let startRotation = 0;
            let targetRotation = 0;
            let animationId = null;
            let currentPrize = null;
            let isOpen = false;
            let scrollPos = 0;

            const prizes = [
                {%- liquid
                    assign angle = 30
                -%}
                {%- for v in (1..6) -%}
                {%- liquid
                    assign icon = 'gift_icon' | append: v
                    assign code = 'discount_code' | append: v
                    assign name = 'prize_name' | append: v
                    assign weight = 'prize_weight' | append: v
                -%}
                {
                    icon: '{{ ds[icon] | image_url: width: 300 }}',
                    code: '{{ ds[code] }}',
                    angle: {{ 360 | minus: angle }},
                    title: `{{ ds[name] }}`,
                    weight: {{ ds[weight] }}}{% if forloop.last == false %},{% endif %}
                {%- liquid
                    assign angle = angle | plus: 60
                -%}
                {%- endfor -%}
            ];

            const getSelectPrize = () => {
                const list = prizes.filter(item => item.weight > 0);
                const len = list.length;
                const totalWeight = list.reduce((prev, cur) => cur.weight + prev, 0);
                const r = Math.random() * totalWeight;
                let cumulative = 0;
                for (let k = 0; k < len; k++) {
                    cumulative += list[k].weight;
                    if (r <= cumulative) return list[k];
                }
                return list[len - 1];
            };

            function startWheel(rotateRad) {
                spinElem.style.transform = `rotate(${rotateRad}deg)`;
            }

            function easeOutCubic(t) {
                return 1 - Math.pow(1 - t, 3);
            }

            function animateSpin(now) {
                const elapsed = now - animStartTime;
                let progress = Math.min(1, elapsed / 1800);
                const easeProgress = easeOutCubic(progress);
                currentRotation = startRotation + (targetRotation - startRotation) * easeProgress;
                startWheel(currentRotation);
                if (progress < 1) {
                    animationId = requestAnimationFrame(animateSpin);
                } else {
                    if (animationId) cancelAnimationFrame(animationId);
                    animationId = null;
                    openModal();
                }
            }

            function startSpin() {
                if (animating) return;
                const minRounds = 6;
                const maxRounds = 14;
                const rounds = Math.round(minRounds + Math.random() * (maxRounds - minRounds));
                currentPrize = getSelectPrize();
                const extraRad = currentPrize.angle;
                const deltaRad = rounds * 360 + extraRad;
                startRotation = currentRotation;
                targetRotation = startRotation + deltaRad;
                animating = true;
                animStartTime = performance.now();
                if (animationId) cancelAnimationFrame(animationId);
                animationId = requestAnimationFrame(animateSpin);
            }

            const successText = () => {
                nodeList.formInfo.innerHTML = `<div class="form-success flex-left">
                    <svg class="icon" viewBox="0 0 1024 1024" xmlns="http://www.w3.org/2000/svg" width="32" height="32">
                        <path
                            d="M512 1024A512 512 0 1 1 512 0a512 512 0 0 1 0 1024z m-49.590857-377.197714L315.977143 498.614857 219.428571 590.848c70.217143 37.814857 168.594286 106.788571 252.854858 213.723429C531.821714 692.662857 715.337143 463.725714 804.571429 443.245714c-14.409143-57.709714-22.528-166.034286 0-223.817143-183.003429 120.685714-342.162286 427.373714-342.162286 427.373715z"
                            fill="#1afa29"></path>
                    </svg>
                    <span>{{ ss.success }}</span>
                </div>`;
            }

            const klaviyoSubscribe = async (email) => {
                const createSubscriptionResponse = await fetch(`https://a.klaviyo.com/client/subscriptions/?company_id={{ ss.klaviyo_api_key }}`, {
                    method: "POST",
                    headers: {
                        accept: "application/json",
                        revision: "2026-04-15",
                        "content-type": "application/json"
                    },
                    body: JSON.stringify({
                        data: {
                            type: "subscription",
                            relationships: {
                                list: {
                                    data: {
                                        type: "list",
                                        id: '{{ ss.klaviyo_list_id }}'
                                    }
                                }
                            },
                            attributes: {
                                profile: {
                                    data: {
                                        type: "profile",
                                        attributes: {
                                            email: email
                                        }
                                    }
                                }
                            }
                        }
                    })
                });
                if (!createSubscriptionResponse.ok) {
                    return alert(` HTTP ${createSubscriptionResponse.status}`);
                }
                successText();
                startSpin();
            };

            form.addEventListener('submit', ev => {
                ev.stopImmediatePropagation();
                ev.preventDefault();
                klaviyoSubscribe(nodeList.email.value);
            });

            nodeList.privacy?.addEventListener('click', (ev) => {
                if (ev.target.tagName.toLocaleLowerCase() === 'a') {
                    return false;
                }
                ev.preventDefault();
                ev.stopPropagation();
                nodeList.privacy.classList.toggle('checked');
                if (nodeList.privacy.classList.contains('checked')) {
                    nodeList.submit.removeAttribute('disabled');
                } else {
                    nodeList.submit.setAttribute('disabled', true);
                }
            });

            function openModal() {
                if (isOpen) return;
                isOpen = true;
                nodeList.prizeName.textContent = currentPrize.title;
                nodeList.code.textContent = currentPrize.code;
                nodeList.cover.innerHTML = `<img src="${currentPrize.icon}" class="image" alt="${currentPrize.code}"/>`
                nodeList.btn.href = '/discount/' + currentPrize.code + '?redirect=' + encodeURIComponent('{{ ss.model_button_url }}');
                nodeList.modal.style.setProperty('--background', `url("{{ ds.model_bg_image | image_url: width: 500 }}")`);
                scrollPos = window.scrollY;
                document.body.style.overflow = 'hidden';
                document.body.style.position = 'fixed';
                document.body.style.top = '-' + scrollPos + 'px';
                document.body.style.width = '100%';
                nodeList.overlay.style.display = 'flex';
                history.pushState({easter: true}, '');
                spawnConfetti();
            }

            function closeModal() {
                if (!isOpen) return;
                isOpen = false;
                nodeList.overlay.style.display = 'none';
                document.body.style.overflow = '';
                document.body.style.position = '';
                document.body.style.top = '';
                document.body.style.width = '';
                window.scrollTo(0, scrollPos);
                if (eggElement && eggElement.parentNode) {
                    eggElement.parentNode.removeChild(eggElement);
                    eggElement = null;
                }
            }

            nodeList.close.addEventListener('click', closeModal);
            nodeList.overlay.addEventListener('click', function (e) {
                if (e.target === nodeList.overlay) closeModal();
            });

            window.addEventListener('popstate', function () {
                if (isOpen) closeModal();
            });

            function spawnConfetti() {
                // Clear existing confetti
                while (nodeList.confetti.firstChild) {
                    nodeList.confetti.removeChild(nodeList.confetti.firstChild);
                }
                const emojis = ['\uD83E\uDD5A', '\uD83D\uDC23', '\uD83D\uDC30', '\uD83C\uDF38', '\uD83C\uDF37', '\u2728'];
                const pieces = 24;
                for (let i = 0; i < pieces; i++) {
                    let el = document.createElement('div');
                    el.className = 'easter-confetti-piece';
                    el.textContent = emojis[i % emojis.length];
                    el.style.left = Math.random() * 100 + '%';
                    el.style.fontSize = (14 + Math.random() * 14) + 'px';
                    el.style.animationDelay = (Math.random() * 0.8) + 's';
                    el.style.animationDuration = (2 + Math.random() * 1.5) + 's';
                    nodeList.confetti.appendChild(el);
                }
            }

            nodeList.copy.addEventListener('click', function () {
                const code = nodeList.code.textContent;
                if (navigator.clipboard && navigator.clipboard.writeText) {
                    navigator.clipboard.writeText(code).then(function () {
                        nodeList.copy.classList.add('active');
                        setTimeout(function () {
                            nodeList.copy.classList.remove('active');
                        }, 2000);
                    });
                } else {
                    const ta = document.createElement('textarea');
                    ta.value = code;
                    ta.style.position = 'fixed';
                    ta.style.left = '-9999px';
                    document.body.appendChild(ta);
                    ta.select();
                    document.execCommand('copy');
                    document.body.removeChild(ta);
                    nodeList.copy.classList.add('active');
                    setTimeout(function () {
                        nodeList.copy.classList.remove('active');
                    }, 2000);
                }
            });

            function init() {
                {%- if request.design_mode -%}
                currentPrize = prizes[0];
                openModal();
                {%- endif -%}
            }

            // init();
        });
    </script>
{%- endif -%}
{% schema %}
