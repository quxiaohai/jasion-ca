{%- liquid
  assign ss = section.settings
  assign size = section.blocks.size
  assign aspect_ratio = '1.479'
  if ss.pc_card_border_image != blank
    assign aspect_ratio = ss.pc_card_border_image.aspect_ratio
  endif
  assign mb_aspect_ratio = aspect_ratio
  if ss.mb_card_border_image != blank
    assign mb_aspect_ratio = ss.mb_card_border_image.aspect_ratio
  endif
-%}
<style>
  .mc_patrol-photo-wall {
    padding: 80px 0;
    background-color: #000000;
    overflow: hidden;
  }
  @keyframes loop-image {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
  .mc_patrol-photo-wall .wall-content {
    width: 100%;
    overflow-x: hidden;
    display: flex;
    margin-bottom: 30px;
    position: relative;
  }
  .mc_patrol-photo-wall .wall-content:last-of-type {
    margin-bottom: 0;
  }
  .mc_patrol-photo-wall .wall-content .marquee-box {
    flex: 0 0 auto;
    min-width: 100%;
    z-index: 1;
    display: flex;
    flex-direction: row;
    animation: var(--duration) linear 1s infinite normal none running loop-image;
    flex-wrap: nowrap;
    animation-direction: var(--direction);
    overflow: hidden;
  }
  .mc_patrol-photo-wall .wall-content .marquee-box:hover {
    animation-play-state: paused;
  }
  .mc_patrol-photo-wall .wall-content .img-wrap {
    width: 500px;
    aspect-ratio: {{ aspect_ratio }};
    padding: 1px;
    margin: 0 6px;
  }
  .mc_patrol-photo-wall .wall-content .img-wrap:before {
    content: "";
    width: 100%;
    height: 100%;
    position: absolute;
    background: url("{{ ss.pc_card_border_image | img_url: '500x' }}");
    background-size: 100% 100%;
  }
  @media screen and (max-width: 1023px) {
    .mc_patrol-photo-wall {
      padding: 2.5rem 0;
    }
    .mc_patrol-photo-wall .title,
    .mc_patrol-photo-wall .description {
      text-align: left;
    }
    .mc_patrol-photo-wall .wall-content {
      margin-bottom: 0.53125rem;
    }
    .mc_patrol-photo-wall .wall-content:last-of-type {
      margin-bottom: 0;
    }
    .mc_patrol-photo-wall .wall-content .img-wrap {
      width: 9.15625rem;
      margin: 0 0.09375rem;
    }
    .mc_patrol-photo-wall .wall-content .img-wrap {
      aspect-ratio: {{ mb_aspect_ratio }};
    }
    .mc_patrol-photo-wall .wall-content .marquee-box:hover {
      animation-play-state: running;
    }
  {%- if ss.mb_card_border_image != blank -%}
    .mc_patrol-photo-wall .wall-content .img-wrap:before {
      background: url("{{ ss.mb_card_border_image | img_url: '500x' }}");
    }
  {%- endif -%}
  }
    {% render 'page-wrap-style' %}
</style>
<div class="mc_patrol-photo-wall section--page">
    {% render 'section-title', info: ss, font: 'rushblade' %}
    {%- assign size = section.blocks.size -%}
    {%- for a in (1..2) -%}
        {%- liquid
            if a == 1
                assign duration = size | times: 8.5 | times: ss.loop_speed
            else
                assign duration = size | times: 7.4 | times: ss.loop_speed
            endif
        -%}
        <div class="wall-content">
            <div class="marquee-box"
                 style="--direction: {% if a == 2 %}normal{% else %}reverse{% endif %}; --duration: {{ duration }}s;">
                {%- for v in (1..4) -%}
                    <div class="marquee-items flex-left">
                        {%- for block in section.blocks -%}
                            <div class="img-wrap relative">
                                {%- render 'global-image', image: block.settings.image, sizes: '(min-width: 1024px) 400w, 600w' -%}
                            </div>
                        {%- endfor -%}
                    </div>
                {%- endfor -%}
            </div>
        </div>
    {%- endfor -%}
</div>
{% schema %}
{
  "name": "MC Photo Wall",
  "class": "mc--main",
  "tag": "section",
  "presets": [
    {
      "name": "MC Photo Wall"
    }
  ],
  "settings": [
    {
      "type": "color",
      "id": "page_color",
      "label": "Background Color",
      "default": "#000000"
    },
    {
      "type": "number",
      "id": "page_top",
      "label": "Padding Top"
    },
    {
      "type": "number",
      "id": "page_bottom",
      "label": "padding Bottom"
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show Title",
      "default": true
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Title",
      "default": "<p>Title</p>"
    },
    {
      "type": "range",
      "id": "title_pc_size",
      "label": "Desktop title size",
      "min": 12,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "title_pc_weight",
      "label": "Desktop title weight",
      "min": 200,
      "max": 900,
      "step": 100,
      "unit": "w",
      "default": 700
    },
    {
      "type": "range",
      "id": "title_pc_line",
      "label": "Desktop title line height",
      "min": 100,
      "max": 300,
      "step": 10,
      "unit": "%",
      "default": 120
    },
    {
      "type": "range",
      "id": "title_mb_size",
      "label": "Mobile title size",
      "min": 6,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "title_mb_weight",
      "label": "Mobile title weight",
      "min": 200,
      "max": 900,
      "step": 100,
      "unit": "w",
      "default": 700
    },
    {
      "type": "range",
      "id": "title_mb_line",
      "label": "Mobile title line height",
      "min": 100,
      "max": 300,
      "step": 10,
      "unit": "%",
      "default": 120
    },
    {
      "type": "number",
      "id": "title_margin_bottom",
      "label": "Title margin bottom",
      "default": 16
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "title_bold_color",
      "label": "Title bold color",
      "default": "#ffffff"
    },
    {
      "type": "color_background",
      "id": "title_gradient_color",
      "label": "Title gradient color"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show description",
      "default": false
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>description</p>"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "description_bold_color",
      "label": "Description bold color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "description_pc_size",
      "label": "Desktop description size",
      "min": 12,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "description_pc_line",
      "label": "Desktop description line height",
      "min": 100,
      "max": 300,
      "step": 10,
      "unit": "%",
      "default": 120
    },
    {
      "type": "range",
      "id": "description_mb_size",
      "label": "Mobile description size",
      "min": 6,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "description_mb_line",
      "label": "Mobile description line height",
      "min": 100,
      "max": 300,
      "step": 10,
      "unit": "%",
      "default": 120
    },
    {
      "type": "number",
      "id": "description_pc_margin_bottom",
      "label": "Desktop description margin bottom",
      "default": 40
    },
    {
      "type": "number",
      "id": "description_mb_margin_bottom",
      "label": "Mobile description margin bottom",
      "default": 30
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "range",
      "id": "loop_speed",
      "label": "Loop speed",
      "min": 0.1,
      "max": 2,
      "step": 0.1,
      "unit": "s",
      "default": 1
    },
    {
      "type": "header",
      "content": "Wall card"
    },
    {
      "type": "image_picker",
      "id": "pc_card_border_image",
      "label": "Desktop card border image"
    },
    {
      "type": "image_picker",
      "id": "mb_card_border_image",
      "label": "Mobile card border image"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ]
}
{% endschema %}
