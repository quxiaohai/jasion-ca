{% assign ss = section.settings %}
{%- assign size = section.blocks.size -%}
<style>
    .mc_image-wall {
        padding: 80px 0;
        background-color: #ffffff;
        overflow: hidden;
        position: relative;
    }

    .mc_image-wall.is-drag:before {
        content: '';
        width: 100%;
        height: 100%;
        z-index: 1;
        position: absolute;
        background: transparent;
    }

    .mc_image-wall .wall-content .marquee-box {
        flex: 0 0 auto;
        min-width: 100%;
        z-index: 1;
        display: flex;
        flex-direction: row;
        flex-wrap: nowrap;
        transform: translateX(-33.333%);
        /*transition-property: transform;*/
    }

    .mc_image-wall .wall-content .image {
        height: 27vw;
        max-height: 518px;
        width: auto;
        aspect-ratio: var(--image_ratio);
        border-radius: 1.04vw;
        margin: 0 0.46875vw;
    }

    @media screen and (max-width: 1023px) {
        .mc_image-wall {
            padding: 2.5rem 0;
        }

        .mc_image-wall .wall-content {
            margin-bottom: 0.6875rem;
        }

        .mc_image-wall .wall-content .image {
            height: 17.5rem;
            max-height: none;
            margin: 0 0.3125rem;
            border-radius: 0.333rem;
        }
    }

    {% render 'page-wrap-style' %}
</style>
<div class="mc_image-wall section--page" id="{{ section.id }}-wall">
    {% render 'section-title', info: ss %}
    {%- assign size = section.blocks.size -%}
    {%- assign duration = size | times: 4 | times: ss.loop_speed -%}
    <div class="wall-content flex-left" node-name="drag">
        <div class="marquee-box"
             data-duration="{{ duration | times: 1000 }}"
             data-direct="{% if ss.slide_direction == 'left' %}-{% endif %}1"
             node-name="marquee">
            {%- for v in (1..3) -%}
                <div class="marquee-items flex-left">
                    {%- for block in section.blocks -%}
                        {%- liquid
                            assign bs = block.settings
                            assign image_ratio = '--image_ratio: 85/100'
                            if bs.image_ratio != blank
                                assign image_ratio = '--image_ratio: ' | append: bs.image_ratio
                            endif
                        -%}
                        {%- render 'global-image', image: block.settings.image, image_size: 600, style: image_ratio, sizes: '(min-width: 1024px) 400w, 600w' -%}
                    {%- endfor -%}
                </div>
            {%- endfor -%}
        </div>
    </div>
</div>
<script>
    {%- render 'infinite-loop' -%}
</script>
{% schema %}
{
  "name": "MC Image Wall",
  "class": "mc--main",
  "tag": "section",
  "presets": [
    {
      "name": "MC Image Wall"
    }
  ],
  "settings": [
    {
      "type": "color",
      "id": "page_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "number",
      "id": "page_top",
      "label": "Padding Top"
    },
    {
      "type": "number",
      "id": "page_bottom",
      "label": "padding Bottom"
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show Title",
      "default": false
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title",
      "default": "Title"
    },
    {
      "type": "range",
      "id": "title_pc_size",
      "label": "Desktop title size",
      "min": 12,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "title_mb_size",
      "label": "Mobile title size",
      "min": 6,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "number",
      "id": "title_margin_bottom",
      "label": "Title margin bottom",
      "default": 16
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#000000"
    },
    {
      "type": "color_background",
      "id": "title_gradient_color",
      "label": "Title gradient color"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show description",
      "default": false
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>description</p>"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "description_pc_size",
      "label": "Desktop description size",
      "min": 12,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "description_mb_size",
      "label": "Mobile description size",
      "min": 6,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "number",
      "id": "description_pc_margin_bottom",
      "label": "Desktop description margin bottom",
      "default": 40
    },
    {
      "type": "number",
      "id": "description_mb_margin_bottom",
      "label": "Mobile description margin bottom",
      "default": 30
    },
    {
      "type": "header",
      "content": "Slide image"
    },
    {
      "type": "range",
      "id": "loop_speed",
      "label": "Loop speed",
      "min": 0.1,
      "max": 2,
      "step": 0.1,
      "unit": "s",
      "default": 1
    },
    {
      "type": "select",
      "id": "slide_direction",
      "label": "Slide direction",
      "options": [
        {
          "value": "left",
          "label": "From right to left"
        },
        {
          "value": "right",
          "label": "From left to right"
        }
      ],
      "default": "left"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "image_ratio",
          "label": "Image ratio"
        }
      ]
    }
  ]
}
{% endschema %}
