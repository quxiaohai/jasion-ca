      "min": 6,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "description_mb_line",
      "label": "Mobile description line height",
      "min": 100,
      "max": 300,
      "step": 10,
      "unit": "%",
      "default": 120
    },
    {
      "type": "number",
      "id": "description_pc_margin_bottom",
      "label": "Desktop description margin bottom",
      "default": 40
    },
    {
      "type": "number",
      "id": "description_mb_margin_bottom",
      "label": "Mobile description margin bottom",
      "default": 30
    },
    {
      "type": "header",
      "content": "Gift card"
    },
    {
      "type": "color",
      "id": "card_title_color",
      "label": "Card title color",
