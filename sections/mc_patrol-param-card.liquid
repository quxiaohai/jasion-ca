    {
      "type": "range",
      "id": "title_mb_weight",
      "label": "Mobile title weight",
      "min": 200,
      "max": 900,
      "step": 100,
      "unit": "w",
      "default": 700
    },
    {
      "type": "range",
      "id": "title_mb_line",
      "label": "Mobile title line height",
      "min": 100,
      "max": 300,
      "step": 10,
      "unit": "%",
      "default": 120
    },
    {
      "type": "number",
