<style>
    #shopify-section-{{ section.id }} {
        --section-padding-top: {{ section.settings.padding_top }}px;
        --section-padding-bottom: {{ section.settings.padding_bottom }}px;
    }

    #shopify-section-{{ section.id }} .article-content .article .rte :is(figure, .image-with-text) {
        margin-inline: 0;
    }

    #shopify-section-{{ section.id }} iframe {
        width: 100% !important;
        height: auto !important;
        aspect-ratio: 1.777;
    }

    .reading-progress {
        position: sticky;
        top: 0;
        left: 0;
        z-index: 99;
        width: 100%;
        height: 4px;
    }

    .reading-progress .progress {
        width: 100%;
        height: 100%;
        background-color: #ff9500;
        transform: translateX(-100%);
    }
</style>

{%- liquid
    echo 'article.css' | asset_url | stylesheet_tag

    # theme-check-disable UndefinedObject
    assign number_of_comments = article.comments_count
    if comment.status == 'pending'
        assign number_of_comments = article.comments_count | plus: 1
    endif
    # theme-check-enable UndefinedObject
-%}
<div class="reading-progress overflow-hidden">
    <div class="progress" id="{{ section.id }}-progress">&nbsp;</div>
</div>
<div
    class="section section--padding{% if section.settings.divider %} section--divider{% endif %}{% if section.settings.rounded %} section--rounded relative{% endif %}">
    <div class="grid gap-5" {{ block.shopify_attributes }}>
        <div class="page-width page-width--narrow tw-grid tw-gap-7 article-wrapper">

            <animate-element class="inline-flex flex-wrap items-center md:hidden gap-6" data-animate="fade-up"
                             data-animate-delay="{{ delay | times: 250 }}">
                {%- for tag in article.tags -%}
                    <a href="{{ blog.url }}/tagged/{{ tag | handle }}"
                       class="badge badge--custom tw-text-white tw-bg-vi tw-border-vi font-medium leading-none rounded-full">{{ tag }}</a>
                {%- endfor -%}
            </animate-element>


            {%- assign delay = delay | plus: 1 -%}
            <h1 class="h1 banner__title heading leading-none">
                <split-words class="split-words block" data-animate="fade-up-large"
                             data-animate-delay="{{ delay | times: 250 }}">{{ article.title }}</split-words>
            </h1>

            <div class="tw-flex gap-6 tw-text-vi tw-mt-0 ">
                {%- if article.tags.size > 0 -%}
                    <div class="inline-flex relative hidden md:flex">
                        <a href="{{ blog.url }}/tagged/{{ article.tags[0] | handle }}"
                           class="badge badge--custom tw-text-white tw-bg-vi tw-border-vi font-medium leading-none rounded-full">{{ article.tags[0] }}</a>
                    </div>
                {%- endif -%}
                <div class="inline-flex items-center gap-2 relative tw-mt-0">
                    {%- render 'icon', icon: 'calendar', size: 'xs', class: 'stroke-1' -%}
                    {{- article.published_at | time_tag: format: 'month_day_year' -}}
                </div>
                <div class="inline-flex items-center gap-2 relative tw-capitalize">
                    {%- render 'icon', icon: 'account', size: 'xs', class: 'stroke-1' -%}
                    {%- capture author -%}<span itemprop="name">{{ article.author }}</span>{%- endcapture -%}
                    {{- 'blogs.article.written_by_html' | t: author: author -}}
                </div>
            </div>
        </div>
    </div>
    <div class="page-width{% if section.settings.narrow %} page-width--narrow{% endif %}">
        <div class="flex-between-top tw-pt-6 tw-mt-6 relative article-content">
            {%- comment -%} 提取所有 h2 标签并创建目录 {%- endcomment -%}
            {% assign toc_items = '' %}
            {% assign article_content = article.content %}

            {%- comment -%} 使用 capture 和 for 循环提取 h2 {%- endcomment -%}
            {% capture toc_html %}
                <nav class="article-menu" aria-label="Article Menu" id="{{ section.id }}-nav">
                    <div class="menu-title">Contents</div>
                    <ul>
                        {% assign h2_matches = article_content | split: '<h2' %}
                        {% for match in h2_matches %}
                            {% if forloop.first == false %}
                                {%- liquid
                                    assign texts = match | split: '</h2>'
                                    assign h3_matches = texts | last | split: '<h3'
                                    assign h2_content = texts | first
                                    assign h2_text = h2_content | strip_html | split: '>' | last | strip
                                    assign h2_id = h2_text | handleize
                                -%}
                                <li class="menu-text">
                                    <a href="#{{ h2_id }}"
                                       data-proxy="menu"
                                       node-name="menu"
                                       class="menu-link">
                                        {{ h2_text }}
                                    </a>
                                    {%- if ss.show_h3_tag and h3_matches.size > 0 -%}
                                        <ul class="sub-menu">
                                            {%- for sub_match in h3_matches -%}
                                                {%- unless forloop.first -%}
                                                    {%- liquid
                                                        assign texts = match | split: '</h2>'
                                                        assign h3_content = sub_match | split: '</h3>' | first
                                                        assign h3_text = h3_content | strip_html | split: '>' | last | strip
                                                        assign h3_id = h3_text | handleize
                                                    -%}
                                                    <li>
                                                        <a href="#{{ h3_id }}" data-proxy="menu" node-name="menu"
                                                           class="menu-link">
                                                            {{ h3_text }}
                                                        </a>
                                                    </li>
                                                {%- endunless -%}
                                            {%- endfor -%}
                                        </ul>
                                    {%- endif -%}
                                </li>
                            {% endif %}
                        {% endfor %}
                    </ul>
                </nav>
            {% endcapture %}

            {%- comment -%} 只在有 h2 标签时显示目录 {%- endcomment -%}
            {% assign h2_count = article_content | split: '<h2' | size | minus: 1 %}
            {% if h2_count > 0 %}
                {{ toc_html }}
            {% endif %}
            <article class="article" id="{{ section.id }}-article">
                <div class="rte text-base md:text-lg">
                    {%- liquid
                        assign origin = request.origin
                        assign mapping_config = settings.address_mapping_config | newline_to_br | split: '<br />'
                        assign article_content = article_content | replace: '<img', '<img loading="lazy"'
                        assign img_matches = article_content | split: '<img'
                        for match in img_matches
                            if forloop.first == false
                                assign img = match | split: '>' | first
                                assign src = img | split: 'src="' | last | split: '"' | first
                                assign n_src = src | append: '&width=700'
                                assign article_content = article_content | replace: src, n_src
                            endif
                        endfor
                        assign a_matches = article_content | split: '<a'
                        for match in a_matches
                            if forloop.first == false
                                assign suc = false
                                assign a = match | split: '>' | first
                                assign src = a | split: 'href="' | last | split: '"' | first
                                assign cur = src | split: '?'
                                if cur.size > 1
                                    assign param = cur | last
                                    assign param = '?' | append : param
                                else
                                    assign param = ''
                                endif
                                assign n_src = cur | first
                                if src contains origin
                                    assign n_src = n_src | replace: origin, ''
                                endif
                                for obj in mapping_config
                                    unless suc
                                        assign mapping = obj | split: '|'
                                        assign s_url = mapping | first
                                        if s_url contains origin
                                            assign s_url = s_url | replace: origin, ''
                                        endif
                                        if n_src == s_url
                                            assign suc = true
                                            assign e_url = mapping | last | append: param
                                            assign article_content = article_content | replace: src, e_url
                                        endif
                                    endunless
                                endfor
                            endif
                        endfor
                        assign block_matches = article_content | split: '<blockquote'
                        for match in block_matches
                            if forloop.first == false and match contains 'application/ld+json'
                                assign json = match | split: '</blockquote>' | first | split: '>' | last
                                assign o_text = '<blockquote data-type="application/ld+json">' | append: json | append: '</blockquote>'
                                assign n_text = '<script type="application/ld+json">' | append: json | append: '</script>'
                                assign article_content = article_content | replace: o_text, n_text
                            endif
                        endfor
                        if article_content contains 'data-type="application/ld+json"'
                            assign article_content = article_content | replace: 'data-type="application/ld+json"', 'style="display: none !important;" data-type="application/ld+json"'
                        endif
                    -%}
                    {{- article_content -}}
                </div>
            </article>
        </div>
    </div>
</div>
{%- if section.blocks.size > 0 -%}
    <div class="comments-section section{% if section.settings.rounded %} section--rounded relative{% endif %}">
        <div class="page-width{% if section.settings.narrow %} page-width--narrow{% endif %} relative grid gap-8">
            {%- for block in section.blocks -%}
                {%- case block.type -%}
                    {%- when '@app' -%}
                        {%- render block -%}

                    {%- when 'spacing' -%}
                        <empty-element
                            class="block spacing-section{% if block.settings.height_mobile == 0 %} hidden lg:block{% endif %}{% if block.settings.height == 0 %} lg:hidden{% endif %}"
                            style="--spacing-height-desktop: {{ block.settings.height }}px; --spacing-height-mobile: {{ block.settings.height_mobile }}px;" {{ block.shopify_attributes }}></empty-element>

                    {%- when 'share' -%}
                        <div class="flex flex-wrap items-center justify-between" {{ block.shopify_attributes }}>
                            {%- liquid
                                assign article_url = request.origin | append: article.url
                                render 'social-sharing', section_id: section.id, share_id: article.id, share_label: block.settings.share_label, share_title: article.title, share_link: article_url, share_image: article.image
                            -%}

                            {%- if block.settings.show_comments -%}
                                <span class="comment-count inline-flex gap-2 text-xs">
                  {%- render 'icon', icon: 'comment', size: 'xs', class: 'stroke-1' -%}
                  <a class="reversed-link" href="#comments">
                    {{- 'blogs.comments.with_count' | t: count: number_of_comments -}}
                  </a>
                </span>
                            {%- endif -%}
                        </div>

                    {%- when 'next_previous_posts' -%}
                        {%- if blog.next_article or blog.previous_article -%}
                            <ul class="grid md:grid-cols-2 gap-5" {{ block.shopify_attributes }}>
                                {%- if blog.previous_article -%}
                                    <li class="article-card flex gap-5">
                                        {%- render 'icon', icon: 'arrow-left', class: 'transform flex-auto' -%}
                                        <div class="flex flex-col gap-3 grow">
                                            {%- if block.settings.show_date or block.settings.show_comments or block.settings.show_author -%}
                                                <ul class="article-card__top flex flex-wrap gap-4">
                                                    {%- if block.settings.show_date -%}
                                                        <li class="inline-flex gap-2 text-xs relative">
                                                            {%- render 'icon', icon: 'calendar', size: 'xs', class: 'stroke-1' -%}
                                                            {{- blog.previous_article.published_at | time_tag: format: 'month_day_year' -}}
                                                        </li>
                                                    {%- endif -%}

                                                    {%- if block.settings.show_comments -%}
                                                        <li class="inline-flex gap-2 text-xs relative">
                                                            {%- render 'icon', icon: 'comment', size: 'xs', class: 'stroke-1' -%}
                                                            <a class="reversed-link"
                                                               href="{{ blog.previous_article.url }}#comments">
                                                                {{- 'blogs.comments.with_count' | t: count: blog.previous_article.comments_count -}}
                                                            </a>
                                                        </li>
                                                    {%- endif -%}

                                                    {%- if block.settings.show_author -%}
                                                        <li class="italic text-xs relative">
                                                            {%- capture author -%}<span
                                                                class="font-medium not-italic">{{ blog.previous_article.author }}</span>{%- endcapture -%}
                                                            {{- 'blogs.article.written_by_html' | t: author: author -}}
                                                        </li>
                                                    {%- endif -%}
                                                </ul>
                                            {%- endif -%}
                                            <p>
                                                <a class="article-card__title heading reversed-link text-lg-2xl leading-tight tracking-tight"
                                                   href="{{ blog.previous_article.url }}">
                                                    {{- blog.previous_article.title -}}
                                                </a>
                                            </p>
                                        </div>
                                    </li>
                                {%- endif -%}

                                {%- if blog.next_article -%}
                                    <li class="article-card flex gap-5">
                                        <div class="flex flex-col gap-3 grow">
                                            {%- if block.settings.show_date or block.settings.show_comments or block.settings.show_author -%}
                                                <ul class="article-card__top flex flex-wrap gap-4">
                                                    {%- if block.settings.show_date -%}
                                                        <li class="inline-flex gap-2 text-xs relative">
                                                            {%- render 'icon', icon: 'calendar', size: 'xs', class: 'stroke-1' -%}
                                                            {{- blog.next_article.published_at | time_tag: format: 'month_day_year' -}}
                                                        </li>
                                                    {%- endif -%}

                                                    {%- if block.settings.show_comments -%}
                                                        <li class="inline-flex gap-2 text-xs relative">
                                                            {%- render 'icon', icon: 'comment', size: 'xs', class: 'stroke-1' -%}
                                                            <a class="reversed-link"
                                                               href="{{ blog.next_article.url }}#comments">
                                                                {{- 'blogs.comments.with_count' | t: count: blog.next_article.comments_count -}}
                                                            </a>
                                                        </li>
                                                    {%- endif -%}

                                                    {%- if block.settings.show_author -%}
                                                        <li class="italic text-xs relative">
                                                            {%- capture author -%}<span
                                                                class="font-medium not-italic">{{ blog.next_article.author }}</span>{%- endcapture -%}
                                                            {{- 'blogs.article.written_by_html' | t: author: author -}}
                                                        </li>
                                                    {%- endif -%}
                                                </ul>
                                            {%- endif -%}
                                            <p>
                                                <a class="article-card__title heading reversed-link text-lg-2xl leading-tight tracking-tight"
                                                   href="{{ blog.next_article.url }}">
                                                    {{- blog.next_article.title -}}
                                                </a>
                                            </p>
                                        </div>
                                        {%- render 'icon', icon: 'arrow-right', class: 'transform flex-auto' -%}
                                    </li>
                                {%- endif -%}
                            </ul>
                        {%- endif -%}

                    {%- when 'comments' -%}
                        {%- if blog.comments_enabled? -%}
                            <div class="comments-wrapper grid gap-5 md:gap-12">
                                {%- paginate article.comments by 5 -%}
                                    {%- if number_of_comments > 0 -%}
                                        <div class="flex flex-col gap-5 md:gap-12">
                                            <h3 class="heading lg:text-3xl text-2xl leading-none tracking-tight text-center md:text-left">
                                                {{- 'blogs.comments.with_count' | t: count: number_of_comments -}}
                                            </h3>

                                            <ul class="grid gap-5">
                                                {% # theme-check-disable UndefinedObject              %}
                                                {%- if comment.status == 'pending' -%}
                                                    <li id="Comment-{{ comment.id }}" class="comment-card">
                                                        {%- render 'article-comment', comment: comment, show_gravatar: block.settings.show_gravatar -%}
                                                    </li>
                                                {%- endif -%}
                                                {% # theme-check-enable UndefinedObject              %}

                                                {%- for comment in article.comments -%}
                                                    <li id="Comment-{{ comment.id }}" class="comment-card">
                                                        {%- render 'article-comment', comment: comment, show_gravatar: block.settings.show_gravatar -%}
                                                    </li>
                                                {%- endfor -%}
                                            </ul>

                                            {%- liquid
                                                if paginate.pages > 1
                                                    render 'pagination', paginate: paginate, hash: '#comments'
                                                endif
                                            -%}
                                        </div>
                                    {%- endif -%}

                                    <div id="comments">
                                        {%- form 'new_comment', article, class: 'new-comment grid gap-8' -%}
                                            {%- liquid
                                                if form.errors
                                                    assign form_errors = form.errors | default_errors
                                                    render 'alert', status: 'error', content: form_errors
                                                endif

                                                if form.posted_successfully?
                                                    if blog.moderated?
                                                        assign success_message = 'blogs.comments.success_moderated' | t
                                                    else
                                                        assign success_message = 'blogs.comments.success' | t
                                                    endif
                                                    render 'alert', status: 'success', content: success_message
                                                endif
                                            -%}

                                            <div class="grid gap-2">
                                                <h3 class="heading lg:text-3xl text-2xl leading-none tracking-tight">{{ 'blogs.comments.title' | t }}</h3>
                                                {%- if blog.moderated? -%}
                                                    <p class="text-sm">{{ 'blogs.comments.moderated' | t }}</p>
                                                {%- endif -%}
                                            </div>
                                            <div class="grid gap-3d5 md:gap-4">
                                                <div class="grid md:grid-cols-2 gap-3d5 md:gap-4">
                                                    <div class="field">
                                                        <input required class="input is-floating" type="text"
                                                               name="comment[author]" id="CommentAuthor"
                                                               value="{{ form.author }}"
                                                               placeholder="{{ 'blogs.comments.name' | t | escape }}"
                                                               autocapitalize="words"/>
                                                        <label class="label is-floating"
                                                               for="CommentAuthor">{{ 'blogs.comments.name' | t }}</label>
                                                    </div>
                                                    <div class="field">
                                                        <input required class="input is-floating" type="email"
                                                               name="comment[email]" id="CommentEmail"
                                                               value="{{ form.email }}"
                                                               placeholder="{{ 'blogs.comments.email' | t | escape }}"
                                                               autocorrect="off" autocapitalize="off"/>
                                                        <label class="label is-floating"
                                                               for="CommentEmail">{{ 'blogs.comments.email' | t }}</label>
                                                    </div>
                                                </div>
                                                <div class="field">
                                                    <textarea required class="textarea is-floating" name="comment[body]"
                                                              id="CommentBody" placeholder=" "
                                                              rows="5">{{ form.body }}</textarea>
                                                    <label class="label is-floating"
                                                           for="CommentBody">{{ 'blogs.comments.message' | t }}</label>
                                                </div>
                                                <div class="field">
                                                    <button type="submit" class="button button--primary button--fixed"
                                                            is="hover-button">
                                                        <span class="btn-fill" data-fill></span>
                                                        <span class="btn-text">{{ 'blogs.comments.post' | t }}</span>
                                                    </button>
                                                </div>
                                                {%- comment -%}
                                                  Remove the following three lines of code to remove the note
                                                  about being protected by Google's reCAPTCHA service.
                                                  By removing it, the small reCAPTCHA widget will appear in the
                                                  bottom right corner of the page.
                                                {%- endcomment -%}
                                                <div class="rte text-sm">
                                                    {% # theme-check-disable TranslationKeyExists              %}
                                                    {{- 'shopify.online_store.spam_detection.disclaimer_html' | t -}}
                                                    {% # theme-check-enable TranslationKeyExists              %}
                                                </div>
                                            </div>
                                        {%- endform -%}
                                    </div>
                                {%- endpaginate -%}
                            </div>
                        {%- endif -%}

                    {%- when 'liquid' -%}
                        {%- if block.settings.liquid != blank -%}
                            <div class="rte" {{ block.shopify_attributes }}>
                                {{- block.settings.liquid -}}
                            </div>
                        {%- endif -%}
                {%- endcase -%}
            {%- endfor -%}
        </div>
    </div>
{%- endif -%}

<script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Article",
      "headline": {{ article.title | json }},
    "author": {
      "@type": "Person",
      "name": {{ article.author | json }}
    },
    "datePublished": {{ article.published_at | date: "%Y-%m-%d" | json }},
    "dateModified": {{ article.updated_at | date: "%Y-%m-%d" | json }},
    "image": {{ article.image | img_url: 'large' | prepend: 'https:' | json }},
    "url": {{ shop.url | append: article.url | json }},
    "publisher": {
      "@type": "Organization",
      "name": {{ shop.name | json }},
      "logo": {
        "@type": "ImageObject",
        "url": "{{ settings.logo | image_url: width: settings.logo.width | prepend: 'https:' }}"
      }
    }
  }
</script>
<script>
    $heybike.on('DOMContentLoaded', () => {
        const main = document.getElementById('shopify-section-{{ section.id }}');
        const progress = document.getElementById('{{ section.id }}-progress');
        const navElem = document.getElementById('{{ section.id }}-nav');
        const articleElem = document.getElementById('{{ section.id }}-article');
        const h2List = Array.from(articleElem.querySelectorAll('h2'));
        const h3List = {% if ss.show_h3_tag %}Array.from(articleElem.querySelectorAll('h3')){% else %}[]{% endif %};
        let elemList = [];
        let menuList = [];
        let totalHeight = main.scrollHeight;
        let currentIndex = $heybike.ref(-1);
        [].concat($heybike.getNodeList(navElem).menu).forEach(elem => {
            menuList.push({
                elem,
                text: elem.innerText.trim()
            })
        });
        const initOffset = () => {
            const list = [];
            h2List.concat(h3List).forEach(elem => {
                const text = elem.innerText.trim();
                list.push({
                    text,
                    elem: menuList.find(item => item.text === text)?.elem,
                    top: $heybike.getOffset(elem).top
                })
            });
            elemList = list.sort((a, b) => a.top - b.top);
        }
        !$heybike.isMobile && initOffset();
        $heybike.on('resize', () => {
            !$heybike.isMobile && initOffset();
            totalHeight = main.scrollHeight;
        }, articleElem);
        $heybike.watch(currentIndex, (n, o) => {
            menuList.forEach(item => item.elem.classList.remove('active'));
            n > -1 && elemList[n].elem?.classList.add('active');
        });

        $heybike.on('scroll', ({top}) => {
            const val = 1 - Math.min(1, top / totalHeight);
            progress.style.transform = `translateX(${-val * 100}%)`;
        });

        function onScroll({top}) {
            if ($heybike.isMobile) {
                return false;
            }
            top = top + 60;
            if (top < elemList[0]?.top) {
                currentIndex.value = -1;
                return false;
            }
            elemList.forEach((item, i) => {
                if (!item) {
                    return false;
                }
                if (top >= item.top) {
                    const next = elemList[i + 1]?.top;
                    if ((!next || top < next) && currentIndex.value !== i) {
                        currentIndex.value = i;
                    }
                }
            });
        }

        !$heybike.isMobile && $heybike.on('scroll', onScroll);
        $heybike.proxy(navElem, 'menu', ({elem, event}) => {
            const text = elem.innerText.trim();
            const index = elemList.findIndex(item => item.text === text);
            if (index > -1) {
                $heybike.off('scroll', onScroll);
                window.scrollTo({
                    top: elemList[index].top - 80,
                    behavior: 'smooth'
                });
                currentIndex.value = index;
                $heybike.debounce(() => {
                    $heybike.on('scroll', onScroll);
                }, 1500, '{{ section.id }}');
            }
            event.preventDefault();
        });
    });
</script>

{% schema %}
{
  "name": "t:sections.main-article.name",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.global.settings.header__section.content"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:sections.global.settings.padding_top.label",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "t:sections.global.settings.padding_bottom.label",
      "default": 100
    },
    {
      "type": "checkbox",
      "id": "divider",
      "label": "t:sections.global.settings.divider.label",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "narrow",
      "label": "t:sections.global.settings.narrow.label",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "rounded",
      "default": false,
      "label": "t:sections.global.settings.rounded.label"
    },
    {
      "type": "header",
      "content": "Article"
    },
    {
      "type": "checkbox",
      "id": "show_h3_tag",
      "label": "Show menu h3 tag",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "share",
      "name": "t:sections.main-article.blocks.share.name",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "share_label",
          "label": "t:sections.global.settings.text.label",
          "default": "Share"
        },
        {
          "type": "paragraph",
          "content": "t:sections.main-article.blocks.share.settings.featured_image_info.content"
        },
        {
          "type": "paragraph",
          "content": "t:sections.main-article.blocks.share.settings.title_info.content"
        },
        {
          "type": "checkbox",
          "id": "show_comments",
          "label": "t:sections.main-article.settings.show_comments.label",
          "default": true
        }
      ]
    },
    {
      "type": "next_previous_posts",
      "name": "t:sections.main-article.blocks.next_previous_posts.name",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "show_date",
          "label": "t:sections.main-article.settings.show_date.label",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_comments",
          "label": "t:sections.main-article.settings.show_comments.label",
          "default": false
        },
        {
          "type": "checkbox",
          "id": "show_author",
          "label": "t:sections.main-article.settings.show_author.label",
          "default": true
        }
      ]
    },
    {
      "type": "comments",
      "name": "t:sections.main-article.blocks.comments.name",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "show_gravatar",
          "label": "t:sections.main-article.blocks.comments.settings.show_gravatar.label",
          "default": true
        }
      ]
    },
    {
      "type": "liquid",
      "name": "t:sections.custom-liquid.name",
      "settings": [
        {
          "type": "liquid",
          "id": "liquid",
          "label": "t:sections.custom-liquid.settings.liquid.label",
          "info": "t:sections.custom-liquid.settings.liquid.info"
        }
      ]
    },
    {
      "type": "spacing",
      "name": "t:sections.empty-space.name",
      "settings": [
        {
          "type": "range",
          "id": "height",
          "label": "t:sections.empty-space.settings.height.label",
          "default": 40,
          "min": 0,
          "max": 120,
          "step": 4,
          "unit": "px"
        },
        {
          "type": "range",
          "id": "height_mobile",
          "label": "t:sections.empty-space.settings.height_mobile.label",
          "default": 28,
          "min": 0,
          "max": 120,
          "step": 4,
          "unit": "px"
        }
      ]
    }
  ]
}
{% endschema %}
