{%- liquid
    assign ss = section.settings
    assign cid = section.id | split: '__' | last
    assign aspect_ratio = '16 / 9'
    if ss.show_border_image and ss.pc_border_image != blank
        assign aspect_ratio = ss.pc_border_image.aspect_ratio
    elsif ss.media_image != blank
        assign aspect_ratio = ss.media_image
    endif
    assign mb_aspect_ratio = aspect_ratio
    if ss.show_border_image and ss.mb_border_image != blank
        assign mb_aspect_ratio = ss.mb_border_image.aspect_ratio
    elsif ss.mb_media_image != blank
        assign mb_aspect_ratio = ss.mb_media_image
    endif
-%}
<style>
    .{{ cid }} {
        background-color: #000000;
        padding: 80px 0;
    }
    .{{ cid }} .border-image {
      object-fit: contain;
      margin-bottom: 48px;
    }
    .{{ cid }} .media-content {
        width: {{ ss.image_width }}%;
        box-sizing: border-box;
        aspect-ratio: {{ aspect_ratio }};
        padding: {% if ss.show_border_image %}{{ ss.pc_border_thickness }}{% else %}0{% endif %};
    }

    {%- if ss.show_border_image -%}
    .{{ cid }} .media-content > .image {
        position: absolute;
        top: 0;
        left: 0;
        object-fit: fill;
    }
    {%- endif -%}
    .{{ cid }} .media-content .media-info .image {
        object-fit: cover;
    }

    @media screen and (max-width: 1023px) {
      .{{ cid }} {
        padding: 40px 0;
      }
        .{{ cid }} .media-content {
            width: 100%;
            aspect-ratio: {{ mb_aspect_ratio }};
            padding: {% if ss.show_border_image %}{{ ss.mb_border_thickness }}{% else %}0{% endif %};
        }
      .{{ cid }} .border-image {
        margin-bottom: 16px;
      }
    }

    {% render 'page-wrap-style' %}
</style>
<div class="{{ cid }} section--page w-full">
    {%- render 'section-title', info: ss, font: 'rushblade' -%}
    {%- if ss.bottom_image != blank -%}
        {%- render 'global-image',
            desktop_img: ss.bottom_image,
            mobile_img: ss.mb_bottom_image,
            desktop_class: 'border-image'
        -%}
    {%- endif -%}
    <div class="page-width flex-center">
        <animate-element data-repeat class="media-content relative">
            {%- if ss.show_border_image -%}
                {%- render 'global-image',
                    desktop_img: ss.pc_border_image,
                    desktop_size: 1440,
                    mobile_img: ss.mb_border_image,
                    mobile_size: 750
                -%}
            {%- endif -%}
            <div class="media-info z-2 w-full h-full relative">
                {%- render 'global-image',
                    desktop_img: ss.media_image,
                    desktop_size: 1440,
                    mobile_img: ss.mb_media_image,
                    mobile_size: 750
                -%}
            </div>
        </animate-element>
    </div>
</div>
{% schema %}
{
  "name": "MC Patrol Media",
  "class": "mc--main",
  "tag": "section",
  "presets": [
    {
      "name": "MC Patrol Media"
    }
  ],
  "settings": [
    {
      "type": "color",
      "id": "page_color",
      "label": "Background Color"
    },
    {
      "type": "number",
      "id": "page_top",
      "label": "Padding Top"
    },
    {
      "type": "number",
      "id": "page_bottom",
      "label": "padding Bottom"
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "label": "Show Title",
      "default": true
    },
    {
      "type": "richtext",
      "id": "title",
      "label": "Title",
      "default": "<p>Title</p>"
    },
    {
      "type": "range",
      "id": "title_pc_size",
      "label": "Desktop title size",
      "min": 12,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "title_pc_weight",
      "label": "Desktop title weight",
      "min": 200,
      "max": 900,
      "step": 100,
      "unit": "w",
      "default": 700
    },
    {
      "type": "range",
      "id": "title_pc_line",
      "label": "Desktop title line height",
      "min": 100,
      "max": 300,
      "step": 10,
      "unit": "%",
      "default": 120
    },
    {
      "type": "range",
      "id": "title_mb_size",
      "label": "Mobile title size",
      "min": 6,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "title_mb_weight",
      "label": "Mobile title weight",
      "min": 200,
      "max": 900,
      "step": 100,
      "unit": "w",
      "default": 700
    },
    {
      "type": "range",
      "id": "title_mb_line",
      "label": "Mobile title line height",
      "min": 100,
      "max": 300,
      "step": 10,
      "unit": "%",
      "default": 120
    },
    {
      "type": "number",
      "id": "title_margin_bottom",
      "label": "Title margin bottom",
      "default": 16
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "title_bold_color",
      "label": "Title bold color",
      "default": "#ffffff"
    },
    {
      "type": "color_background",
      "id": "title_gradient_color",
      "label": "Title gradient color"
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show description",
      "default": false
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>description</p>"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "description_bold_color",
      "label": "Description bold color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "description_pc_size",
      "label": "Desktop description size",
      "min": 12,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "description_pc_line",
      "label": "Desktop description line height",
      "min": 100,
      "max": 300,
      "step": 10,
      "unit": "%",
      "default": 120
    },
    {
      "type": "range",
      "id": "description_mb_size",
      "label": "Mobile description size",
      "min": 6,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "description_mb_line",
      "label": "Mobile description line height",
      "min": 100,
      "max": 300,
      "step": 10,
      "unit": "%",
      "default": 120
    },
    {
      "type": "number",
      "id": "description_pc_margin_bottom",
      "label": "Desktop description margin bottom",
      "default": 40
    },
    {
      "type": "number",
      "id": "description_mb_margin_bottom",
      "label": "Mobile description margin bottom",
      "default": 30
    },
    {
      "type": "header",
      "content": "Banner bottom image"
    },
    {
      "type": "image_picker",
      "id": "bottom_image",
      "label": "Desktop banner bottom image"
    },
    {
      "type": "image_picker",
      "id": "mb_bottom_image",
      "label": "mobile banner bottom image"
    },
    {
      "type": "header",
      "content": "Media image"
    },
    {
      "type": "checkbox",
      "id": "show_border_image",
      "label": "Show media border image",
      "default": false
    },
    {
      "type": "image_picker",
      "id": "pc_border_image",
      "label": "Desktop video border image"
    },
    {
      "type": "text",
      "id": "pc_border_thickness",
      "label": "Desktop video border thickness",
      "default": "27px 27px"
    },
    {
      "type": "image_picker",
      "id": "mb_border_image",
      "label": "Mobile video border image"
    },
    {
      "type": "text",
      "id": "mb_border_thickness",
      "label": "Mobile video border thickness",
      "default": "10px 10px"
    },
    {
      "type": "image_picker",
      "id": "media_image",
      "label": "Desktop media image"
    },
    {
      "type": "range",
      "id": "image_width",
      "label": "Desktop image width",
      "min": 10,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100
    },
    {
      "type": "image_picker",
      "id": "mb_media_image",
      "label": "Mobile media image"
    }
  ]
}
{% endschema %}
