{%- liquid
    assign ss = section.settings
    assign youtubes = section.blocks | where: 'type', 'youtube'
    assign videos = section.blocks | where: 'type', 'video'
-%}
<style>
    .mc_patrol-community-video {
        padding: 58px 0 40px;
        background-color: #000000;
    }

    .mc_patrol-community-video .slide-tabs {
        gap: 10px;
        padding-bottom: 32px;
    }

    .mc_patrol-community-video .button-fold {
        height: 82px;
        min-width: 222px;
        padding: 0 40px;
        background: linear-gradient(45deg, transparent 24px, {{ ss.tab_bg_color }} 24px);
        color: {{ ss.tab_color }};
        font-size: 18px;
        transition: background 0.2s;
        gap: 8px;
    }

    .mc_patrol-community-video .button-fold .icon {
        width: 26px;
        height: 26px;
    }

    .mc_patrol-community-video .button-fold.active {
        background: linear-gradient(45deg, transparent 24px, {{ ss.tab_active_bg_color }} 24px);
        font-weight: 700;
        color: {{ ss.tab_active_color }};
    }

    .mc_patrol-community-video .button-fold.active:after {
        border-top-color: {{ ss.tab_active_bg_color }};
    }

    .mc_patrol-community-video .button-fold:before, .mc_patrol-community-video .button-fold:after {
        content: "";
        width: 0;
        height: 0;
        border: 6px solid transparent;
        position: absolute;
    }

    .mc_patrol-community-video .button-fold:before {
        border-bottom-color: {{ ss.page_color }};
        right: 20px;
        bottom: 0;
    }

    .mc_patrol-community-video .button-fold:after {
        border-top-color: {{ ss.tab_bg_color }};
        bottom: -10px;
        right: 30px;
    }

    .mc_patrol-community-video .custom-slide-button {
        padding-right: 0;
    }

    .mc_patrol-community-video .media-content {
        display: none;
    }

    .mc_patrol-community-video .media-content.active {
        display: block;
    }

    .mc_patrol-community-video .media-content > .slider-item ~ .slider-item,
    .mc_patrol-community-video .media-content > .media-item ~ .media-item {
        display: none;
    }

    .mc_patrol-community-video .media-item {
        border-radius: 10px;
        background-color: #4D4D4B;
        min-height: 100%;
        width: calc((100vw - 108px - var(--page-padding) * 2) / 3);
        margin-right: 36px;
    }

    .mc_patrol-community-video .media-item .media {
        width: 100%;
        height: auto;
        aspect-ratio: 16/9;
        object-fit: cover;
        border-radius: 0;
    }

    .mc_patrol-community-video .media-item .media[playing] .deferred-poster .play-button {
        opacity: 0;
    }

    .mc_patrol-community-video .media-item .media .deferred-poster {
        left: 50%;
        transform: translateX(-50%);
        width: 70px;
    }

    .mc_patrol-community-video .media-item .media .deferred-poster .play-button {
        width: 100%;
        height: auto;
        background: none;
        inset-inline: 0;
        inset-block: 0;
    }

    .mc_patrol-community-video .media-item .media .deferred-poster .play-button .icon {
        width: 70px;
        height: 48px;
    }

    .mc_patrol-community-video .media-item .media-info {
        box-sizing: border-box;
        flex: 1;
        padding: 18px 15px 80px;
    }

    .mc_patrol-community-video .media-item .media-info .date {
        font-size: 14px;
        color: #e8e6e6;
        font-weight: 400;
        padding-bottom: 6px;
    }

    .mc_patrol-community-video .media-item .media-info .intro,
    .mc_patrol-community-video .media-item .media-info .name {
        color: #ffffff;
    }

    .mc_patrol-community-video .media-item .media-info .intro {
        font-size: 16px;
    }

    .mc_patrol-community-video .media-item .media-info .user {
        left: 15px;
        bottom: 20px;
    }

    .mc_patrol-community-video .media-item .media-info .user .image {
        width: 38px;
        height: 38px;
        border-radius: 50%;
    }

    .mc_patrol-community-video .media-item .media-info .name {
        font-size: 14px;
        padding-left: 10px;
        max-width: 320px;
        word-break: break-word;
    }

    .mc_patrol-community-video .slider-item {
        display: grid;
        gap: 0 15px;
        min-height: 100%;
        grid-template-rows: auto 1fr;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        opacity: 0.3 !important;
        transition: opacity 0.3s;
        width: calc((100vw - 108px - var(--page-padding) * 2) / 2.5);
        margin-right: 36px;
    }

    .mc_patrol-community-video .slider-item.is-selected {
        opacity: 1 !important;
    }

    .mc_patrol-community-video .slider-item .media-info,
    .mc_patrol-community-video .slider-item .media-image {
        grid-row: span 1/span 1;
        padding-right: 10px;
    }

    .mc_patrol-community-video .slider-item .media-info .image,
    .mc_patrol-community-video .slider-item .media-image .image {
        height: auto;
        aspect-ratio: 1/1;
    }

    .mc_patrol-community-video .slider-item .media-info .button-group,
    .mc_patrol-community-video .slider-item .media-image .button-group {
        padding: 12px 0;
        gap: 12px;
        flex-wrap: wrap;
    }

    .mc_patrol-community-video .slider-item .media-info .button-group .button,
    .mc_patrol-community-video .slider-item .media-image .button-group .button {
        padding: 10px 20px;
        --buttons-radius: 6px;
        --color-button-text: 255 255 255;
        --color-button-background: 0 0 0;
        transition: opacity 0.3s;
    }

    .mc_patrol-community-video .slider-item .media-info .button-group .button:hover,
    .mc_patrol-community-video .slider-item .media-image .button-group .button:hover {
        opacity: 0.9;
    }

    .mc_patrol-community-video .slider-item .media-info .name,
    .mc_patrol-community-video .slider-item .media-image .name {
        font-size: 24px;
        padding-bottom: 10px;
    }

    .mc_patrol-community-video .slider-item .media-info .intro,
    .mc_patrol-community-video .slider-item .media-info .nickname,
    .mc_patrol-community-video .slider-item .media-image .intro,
    .mc_patrol-community-video .slider-item .media-image .nickname {
        font-size: 12px;
        padding-bottom: 10px;
    }

    .mc_patrol-community-video .slider-item .media-info .intro,
    .mc_patrol-community-video .slider-item .media-image .intro {
        padding-bottom: 20px;
    }

    .mc_patrol-community-video .slider-item .media-video {
        grid-row: span 2/span 2;
        display: flex;
        width: 100%;
        height: 100%;
    }

    .mc_patrol-community-video .slider-item .media-video .video {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .custom-slide-button .flickity-enabled {
        padding-bottom: 68px;
        position: relative;
    }

    .custom-slide-button .flickity-button {
        transform: translateY(0);
        inset-block-start: 0;
        bottom: 0;
        width: 48px;
        height: 48px;
        background-color: #fbe309;
        top: auto;
        inset-inline-start: auto;
        right: var(--page-padding);
        display: flex;
    }

    .custom-slide-button .flickity-button:before {
        content: "";
        width: 17px;
        height: 33px;
        position: absolute;
        left: 50%;
        top: 50%;
        transform: translate(-50%, -50%);
        background: url("data:image/png;base64,") no-repeat;
        background-size: 100% 100%;
    }

    .custom-slide-button .flickity-button.next:before {
        transform: translate(-36%, -50%);
    }

    .custom-slide-button .flickity-button.previous {
        transform: translateX(-58px);
    }

    .custom-slide-button .flickity-button.previous:before {
        transform: rotate(180deg) translate(66%, 50%);
    }

    .custom-slide-button .flickity-button svg {
        display: none;
    }

    .custom-slide-button .flickity-button:focus {
        box-shadow: none;
    }

    .custom-slide-button .flickity-button:disabled {
        background-color: #4d4d4b;
        opacity: 1;
    }

    @media screen and (max-width: 2200px) {
        .mc_patrol-community-video .custom-slide-button {
            padding-right: 0;
        }

        .mc_patrol-community-video .media-item {
            width: calc((95.4vw - var(--page-padding) * 2) / 3);
            margin-right: 1.8vw;
        }

        .mc_patrol-community-video .slider-item {
            width: calc((96.4vw - var(--page-padding) * 2) / 2.5);
            margin-right: 1.8vw;
        }

        .mc_patrol-community-video .flickity-button {
            right: var(--page-padding);
        }
    }

    @media screen and (max-width: 1023px) {
        .mc_patrol-community-video {
            padding: 2.5rem 0;
        }

        .mc_patrol-community-video .slide-tabs {
            gap: 0.21875rem;
            padding-bottom: 1.2rem;
        }

        .mc_patrol-community-video .button-fold {
            height: 1.875rem;
            min-width: 5rem;
            padding: 0 0.9375rem;
            background: linear-gradient(45deg, transparent 9px, {{ ss.tab_bg_color }} 9px);
            font-size: 0.625rem;
            gap: 0.3125rem;
        }

        .mc_patrol-community-video .button-fold .icon {
            width: 1.125rem;
            height: 1.125rem;
        }

        .mc_patrol-community-video .button-fold.active {
            background: linear-gradient(45deg, transparent 9px, {{ ss.tab_active_bg_color }} 9px);
        }

        .mc_patrol-community-video .button-fold:before, .mc_patrol-community-video .button-fold:after {
            border-width: 2px;
        }

        .mc_patrol-community-video .button-fold:before {
            right: 10px;
        }

        .mc_patrol-community-video .button-fold:after {
            border-width: 3px;
            bottom: -5px;
            right: 13px;
        }

        .mc_patrol-community-video .media-item {
            width: 18.75rem;
            margin-right: 0.75rem;
            border-radius: 0.5rem;
        }

        .mc_patrol-community-video .media-item .media .deferred-poster {
            width: 3.5625rem;
        }

        .mc_patrol-community-video .media-item .media .deferred-poster .play-button .icon {
            width: 3.5625rem;
            height: 2.53125rem;
        }

        .mc_patrol-community-video .media-item .media-info {
            padding: 1rem 1.125rem 4rem;
        }

        .mc_patrol-community-video .media-item .media-info .date {
            font-size: 0.75rem;
            padding-bottom: 0.3125rem;
        }

        .mc_patrol-community-video .media-item .media-info .intro {
            font-size: 0.8125rem;
        }

        .mc_patrol-community-video .media-item .media-info .user {
            left: 0.75rem;
            bottom: 1.0625rem;
        }

        .mc_patrol-community-video .media-item .media-info .user .image {
            width: 1.90625rem;
            height: 1.90625rem;
        }

        .mc_patrol-community-video .media-item .media-info .name {
            font-size: 0.71875rem;
            padding-left: 0.65625rem;
            max-width: 16.25rem;
        }

        .mc_patrol-community-video .slider-item {
            width: 92%;
            display: flex;
            flex-wrap: wrap;
            align-items: stretch;
            gap: 0;
        }

        .mc_patrol-community-video .slider-item .media-image, .mc_patrol-community-video .slider-item .media-video {
            width: 50%;
        }

        .mc_patrol-community-video .slider-item .media-image {
            grid-column: auto;
            grid-row: auto;
            display: flex;
            flex-direction: column;
            padding-right: 0.375rem;
            width: 50%;
        }

        .mc_patrol-community-video .slider-item .media-image .button-group {
            padding: 8px 0;
            gap: 8px;
            flex-wrap: wrap;
        }

        .mc_patrol-community-video .slider-item .media-image .button-group .button {
            --buttons-radius: 4px;
        }

        .mc_patrol-community-video .slider-item .media-info {
            grid-column: auto;
            grid-row: auto;
            margin-top: 16px;
        }

        .mc_patrol-community-video .slider-item .media-info .name {
            font-size: 1.25rem;
            padding-bottom: 0.625rem;
        }

        .mc_patrol-community-video .slider-item .media-info .intro,
        .mc_patrol-community-video .slider-item .media-info .nickname {
            padding-bottom: 0.625rem;
        }

        .mc_patrol-community-video .slider-item .media-video {
            grid-column: auto;
            grid-row: auto;
            height: auto;
            aspect-ratio: 14/25;
            width: 50%;
            padding-left: 0.375rem;
        }

        .custom-slide-button .flickity-button {
            display: none;
        }

        .custom-slide-button .flickity-enabled {
            padding-bottom: 0;
        }
    }

    {% render 'page-wrap-style' %}
</style>
<div class="mc_patrol-community-video section--page w-full" id="{{ section.id }}-video">
    {% render 'section-title', info: ss, font: 'rushblade' %}
    {%- if youtubes.size > 0 and videos.size > 0 -%}
        <div class="page-width">
            <div class="slide-tabs flex-left">
                <button is="magnet-button" data-proxy="tab" node-name="tab" data-index="0" class="button-fold flex-center active relative">
                    <svg class="icon" viewBox="0 0 1024 1024" xmlns="http://www.w3.org/2000/svg" width="32" height="32">
                        <path
                            d="M1003.2 265.6c-11.2-44.8-46.4-78.4-91.2-91.2-80-20.8-400-20.8-400-20.8s-320 0-400 20.8c-44.8 11.2-78.4 46.4-91.2 91.2C0 345.6 0 512 0 512s0 166.4 20.8 246.4c11.2 44.8 46.4 78.4 91.2 91.2 80 20.8 400 20.8 400 20.8s320 0 400-20.8c44.8-11.2 78.4-46.4 91.2-91.2C1024 678.4 1024 512 1024 512s0-166.4-20.8-246.4z m-593.6 400V358.4L675.2 512 409.6 665.6z"
                            fill="currentColor"
                        ></path>
                    </svg>
                    {{ ss.tab1 }}
                </button>
                <button is="magnet-button" data-proxy="tab" node-name="tab" data-index="1" class="button-fold flex-center relative">
                    <svg class="icon" viewBox="0 0 1024 1024" xmlns="http://www.w3.org/2000/svg" width="32" height="32">
                        <path
                            d="M512 306.9c-113.5 0-205.1 91.6-205.1 205.1S398.5 717.1 512 717.1 717.1 625.5 717.1 512 625.5 306.9 512 306.9z m0 338.4c-73.4 0-133.3-59.9-133.3-133.3S438.6 378.7 512 378.7 645.3 438.6 645.3 512 585.4 645.3 512 645.3zM725.5 250.7c-26.5 0-47.9 21.4-47.9 47.9s21.4 47.9 47.9 47.9 47.9-21.3 47.9-47.9c-0.1-26.6-21.4-47.9-47.9-47.9z"
                            fill="currentColor"
                        ></path>
                        <path
                            fill="currentColor"
                            d="M911.8 512c0-55.2 0.5-109.9-2.6-165-3.1-64-17.7-120.8-64.5-167.6-46.9-46.9-103.6-61.4-167.6-64.5-55.2-3.1-109.9-2.6-165-2.6-55.2 0-109.9-0.5-165 2.6-64 3.1-120.8 17.7-167.6 64.5C132.6 226.3 118.1 283 115 347c-3.1 55.2-2.6 109.9-2.6 165s-0.5 109.9 2.6 165c3.1 64 17.7 120.8 64.5 167.6 46.9 46.9 103.6 61.4 167.6 64.5 55.2 3.1 109.9 2.6 165 2.6 55.2 0 109.9 0.5 165-2.6 64-3.1 120.8-17.7 167.6-64.5 46.9-46.9 61.4-103.6 64.5-167.6 3.2-55.1 2.6-109.8 2.6-165z m-88 235.8c-7.3 18.2-16.1 31.8-30.2 45.8-14.1 14.1-27.6 22.9-45.8 30.2C695.2 844.7 570.3 840 512 840c-58.3 0-183.3 4.7-235.9-16.1-18.2-7.3-31.8-16.1-45.8-30.2-14.1-14.1-22.9-27.6-30.2-45.8C179.3 695.2 184 570.3 184 512c0-58.3-4.7-183.3 16.1-235.9 7.3-18.2 16.1-31.8 30.2-45.8s27.6-22.9 45.8-30.2C328.7 179.3 453.7 184 512 184s183.3-4.7 235.9 16.1c18.2 7.3 31.8 16.1 45.8 30.2 14.1 14.1 22.9 27.6 30.2 45.8C844.7 328.7 840 453.7 840 512c0 58.3 4.7 183.2-16.2 235.8z"
                        ></path>
                    </svg>
                    {{ ss.tab2 }}
                </button>
            </div>
        </div>
    {%- endif -%}
    <div class="custom-slide-button page-width">
        {%- if youtubes.size > 0 -%}
            <slide-element buttons class="media-content active" node-name="panel">
                {%- for block in youtubes -%}
                    {%- assign bs = block.settings -%}
                    <div class="media-item flex-column overflow-hidden relative">
                        {%- capture sizes -%}{% if bs.full_width %}100vw{% else %}min({{ settings.page_width }}px, 100vw){% endif %}{%- endcapture -%}
                        {%- if bs.video_mobile or bs.video_url_mobile -%}
                            {%- render 'video',
                                sizes: sizes,
                                video: bs.video_mobile,
                                video_url: bs.video_url_mobile,
                                muted: bs.enable_video_autoplay,
                                autoplay: bs.enable_video_autoplay,
                                loop: bs.enable_video_looping,
                                description: bs.description,
                                cover_image: bs.cover_image_mobile,
                                show_youtube_button: true,
                                is_mobile: true,
                                controls: true,
                                class: 'media media--height w-full h-full relative'
                            -%}
                        {%- endif -%}
                        {%- render 'video',
                            sizes: sizes,
                            video: bs.video,
                            video_url: bs.video_url,
                            muted: bs.enable_video_autoplay,
                            autoplay: bs.enable_video_autoplay,
                            loop: bs.enable_video_looping,
                            description: bs.description,
                            cover_image: bs.cover_image,
                            show_youtube_button: true,
                            controls: true,
                            class: 'media media--height w-full h-full relative'
                        -%}
                        <div class="media-info relative">
                            <div class="date lh-2">{{ bs.date }}</div>
                            <div class="intro lh-4">{{ bs.content }}</div>
                            {% if bs.avatar and bs.author %}
                                <div class="user absolute flex-left">
                                    {{ bs.avatar | image_url: width: '48' | image_tag: class: 'image', width: '48' }}
                                    <span class="name lh-2">{{ bs.author }}</span>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                {%- endfor -%}
            </slide-element>
        {%- endif -%}
        {%- if videos.size > 0 -%}
            <slide-element buttons class="media-content" node-name="panel">
                {%- for block in videos -%}
                    {%- liquid
                        assign bs = block.settings
                        assign index = forloop.index0
                        assign pc_node = 'pc_kol_' | append: index
                        assign mb_node = 'mb_kol_' | append: index
                    -%}
                    <div data-index="{{ index }}"
                         class="slider-item flex-top relative overflow-hidden {% if forloop.first %}is-selected{% endif %}">
                        <div class="media-image relative">
                            {%- render 'global-image', desktop_img: bs.desktop_image, desktop_size: 400, mobile_img: bs.mobile_image, mobile_size: 400 -%}
                            <div class="button-group flex-left">
                                {%- if bs.show_button1 -%}
                                    <a href="{{ bs.button1_url }}"
                                       style="background: {{ bs.button1_bg_color }}; color: {{ bs.button1_color }};"
                                       class="button">{{ bs.button1 }}</a>
                                {%- endif -%}
                                {%- if bs.show_button2 -%}
                                    <a href="{{ bs.button2_url }}"
                                       style="background: {{ bs.button2_bg_color }}; color: {{ bs.button2_color }};"
                                       class="button">{{ bs.button2 }}</a>
                                {%- endif -%}
                            </div>
                        </div>
                        <div class="media-video">
                            {%- render 'global-video',
                                desktop_video: bs.video,
                                desktop_size: 500,
                                desktop_node: pc_node,
                                desktop_cover: bs.cover_image,
                                mobile_video: bs.video_mobile,
                                mobile_cover: bs.cover_image_mobile,
                                mobile_size: 500,
                                mobile_node: mb_node,
                                frament: true,
                                controls: true,
                                loop: true
                            -%}
                        </div>
                        <div class="media-info tw-relative">
                            <div class="name fw-600 lh-2"
                                 style="color: {{ bs.content_color }};">{{ bs.title }}</div>
                            <div class="intro lh-5"
                                 style="color: {{ bs.content_color }};">{{ bs.content }}</div>
                            <div class="nickname lh-2"
                                 style="color: {{ bs.content_color }};">{{ bs.author }}</div>
                        </div>
                    </div>
                {%- endfor -%}
            </slide-element>
        {%- endif -%}
    </div>
</div>
{%- if videos.size > 0 -%}
<script>
    $heybike.on('DOMContentLoaded', () => {
        const node = document.getElementById('{{ section.id }}-video');
        const nodeList = $heybike.getNodeList(node);

        $heybike.tabSwitch({
            root: node,
            nodeList
        });
        let current = 0;
        const onResetTemp = (index, key) => {
            const elem = nodeList[`${key}_kol_${index}`];
            if (elem?.tagName.toLocaleUpperCase() !== 'video') {
                const templateElement = elem.querySelector(`template`);
                if (templateElement) {
                    const media = templateElement.content.firstElementChild.cloneNode(true);
                    elem.replaceWith(media);
                    nodeList[`${key}_kol_${index}`] = media;
                }
            }
        }

        const onPlay = (index) => {
            const key = $heybike.isMobile ? 'mb' : 'pc';
            onResetTemp(index, key);
            nodeList[`${key}_kol_${index}`]?.play();
        }
        const onPause = (index) => {
            const key = $heybike.isMobile ? 'mb' : 'pc';
            onResetTemp(index, key);
            nodeList[`${key}_kol_${index}`]?.pause();
        }

        $heybike.inView(nodeList.panel[1], () => {
            onPlay(current);
            return () => {
                onPause(current);
            }
        });

        nodeList.panel[1].addEventListener('slider:change', (e) => {
            $heybike.debounce(() => {
                onPause(current);
                current = e.detail.currentPage;
                onPlay(current);
            }, '{{ section.id }}');
        });
    });
</script>
{%- endif -%}
{% schema %}
{
  "name": "MC Patrol Community Video",
  "class": "mc--main",
  "tag": "section",
  "presets": [
    {
      "name": "MC Patrol Community Video"
    }
  ],
  "settings": [
    {
      "type": "color",
      "id": "page_color",
      "label": "Background Color",
      "default": "#000000"
